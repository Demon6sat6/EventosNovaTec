---
import Layout from '../layouts/Layout.astro';
import { createServerClient } from '../lib/supabase';
import HeroBackground from '../components/HeroBackground';

const db = createServerClient();
const { data: eventos } = await db
  .from('eventos')
  .select('*')
  .eq('publicado', true)
  .order('fecha', { ascending: true });
---
<Layout title="Inicio">

<section style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;background:#02020a;">
  <HeroBackground client:only="react" />

  <div style="position:absolute;inset:0;pointer-events:none;z-index:1;">
    <div class="float" style="position:absolute;top:-15%;left:-8%;width:700px;height:700px;background:radial-gradient(circle,rgba(124,58,237,0.1) 0%,transparent 65%);border-radius:50%;"></div>
    <div class="float2" style="position:absolute;bottom:-15%;right:-8%;width:600px;height:600px;background:radial-gradient(circle,rgba(236,72,153,0.08) 0%,transparent 65%);border-radius:50%;"></div>
  </div>

  <div style="position:absolute;bottom:0;left:0;right:0;height:50%;z-index:1;pointer-events:none;">
    <div class="grid-floor" style="width:100%;height:100%;"></div>
  </div>

  <div style="position:absolute;inset:0;z-index:2;pointer-events:none;overflow:hidden;">
    <div style="position:absolute;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(124,58,237,0.6),rgba(236,72,153,0.6),transparent);animation:scan 6s linear infinite;"></div>
  </div>

  <div style="position:relative;z-index:10;max-width:1280px;margin:0 auto;padding:0 40px;width:100%;">
    <div style="max-width:800px;">

      <div style="display:inline-flex;align-items:center;gap:12px;margin-bottom:40px;padding:8px 20px;background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.25);border-radius:100px;backdrop-filter:blur(10px);">
        <span style="width:6px;height:6px;background:#a78bfa;border-radius:50%;box-shadow:0 0 12px #a78bfa;animation:pulse-ring 2s ease-out infinite;"></span>
        <span style="color:#c4b5fd;font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;">Plataforma de eventos en vivo</span>
        <span style="width:1px;height:12px;background:rgba(124,58,237,0.4);"></span>
        <span style="color:rgba(255,255,255,0.3);font-size:11px;">{eventos?.length ?? 0} activos</span>
      </div>

      <div style="position:relative;margin-bottom:32px;">
        <h1 style="font-size:clamp(56px,8vw,108px);font-weight:900;line-height:0.92;letter-spacing:-4px;color:white;font-family:'Space Grotesk',sans-serif;">
          <span style="display:block;color:rgba(255,255,255,0.92);">VIVE</span>
          <span style="display:block;" class="shimmer-text">MOMENTOS</span>
          <span style="display:block;color:rgba(255,255,255,0.92);">ÚNICOS</span>
        </h1>
        <div style="position:absolute;top:0;left:0;right:0;pointer-events:none;overflow:hidden;opacity:0.25;">
          <h1 style="font-size:clamp(56px,8vw,108px);font-weight:900;line-height:0.92;letter-spacing:-4px;color:#7c3aed;font-family:'Space Grotesk',sans-serif;animation:glitch1 10s infinite 3s;">
            <span style="display:block;">VIVE</span>
            <span style="display:block;">MOMENTOS</span>
            <span style="display:block;">ÚNICOS</span>
          </h1>
        </div>
      </div>

      <p style="color:rgba(255,255,255,0.4);font-size:clamp(15px,1.8vw,19px);max-width:520px;line-height:1.75;margin-bottom:48px;font-weight:400;">
        Descubre experiencias extraordinarias. Compra entradas con tecnología QR y accede a los mejores eventos de la ciudad.
      </p>

      <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:72px;">
        <a href="#eventos" class="btn-primary"
          style="display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:700;font-size:14px;padding:16px 36px;border-radius:100px;text-decoration:none;box-shadow:0 8px 32px rgba(124,58,237,0.4),inset 0 1px 0 rgba(255,255,255,0.2);letter-spacing:0.5px;">
          <span>Explorar eventos</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#como-funciona" class="btn-primary"
          style="display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.65);font-weight:600;font-size:14px;padding:16px 36px;border-radius:100px;text-decoration:none;backdrop-filter:blur(10px);letter-spacing:0.5px;">
          <span>Cómo funciona</span>
        </a>
      </div>

      <div style="display:flex;gap:0;border:1px solid rgba(255,255,255,0.06);border-radius:16px;overflow:hidden;backdrop-filter:blur(10px);background:rgba(255,255,255,0.02);width:fit-content;">
        {[
          { num: eventos?.length ?? 0, label: 'Eventos activos' },
          { num: '100%', label: 'Pago seguro' },
          { num: 'QR', label: 'Entrada digital' },
        ].map((s, i) => (
          <div style={`padding:18px 28px;text-align:center;${i < 2 ? 'border-right:1px solid rgba(255,255,255,0.06);' : ''}`}>
            <p style="font-size:26px;font-weight:900;background:linear-gradient(135deg,#a78bfa,#f472b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1;">{s.num}</p>
            <p style="color:rgba(255,255,255,0.25);font-size:11px;margin-top:4px;letter-spacing:1px;text-transform:uppercase;">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div style="position:absolute;bottom:36px;right:48px;z-index:10;display:flex;flex-direction:column;align-items:center;gap:8px;">
    <div style="width:1px;height:60px;background:linear-gradient(to bottom,rgba(124,58,237,0.8),transparent);animation:float3 2s ease-in-out infinite;"></div>
    <span style="color:rgba(255,255,255,0.15);font-size:9px;letter-spacing:3px;text-transform:uppercase;writing-mode:vertical-rl;">scroll</span>
  </div>
</section>

<section id="eventos" style="background:#02020a;padding:120px 0;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;pointer-events:none;">
    <div class="cyber-grid" style="position:absolute;inset:0;opacity:0.5;"></div>
    <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(124,58,237,0.4),rgba(236,72,153,0.4),transparent);"></div>
    <div style="position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(124,58,237,0.2),transparent);"></div>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 40px;position:relative;z-index:1;">
    <div class="reveal" style="margin-bottom:72px;">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
        <div style="width:32px;height:2px;background:linear-gradient(90deg,#7c3aed,#ec4899);"></div>
        <span style="color:#a78bfa;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;">Próximos eventos</span>
      </div>
      <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;">
        <h2 style="font-size:clamp(36px,5vw,58px);font-weight:900;color:white;letter-spacing:-2px;line-height:1;font-family:'Space Grotesk',sans-serif;">
          Elige tu <span class="gradient-text">experiencia</span>
        </h2>
        <div style="display:flex;align-items:center;gap:8px;background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.2);padding:8px 16px;border-radius:100px;">
          <span style="width:6px;height:6px;background:#a78bfa;border-radius:50%;"></span>
          <span style="color:#a78bfa;font-size:12px;font-weight:600;">{eventos?.length ?? 0} disponibles</span>
        </div>
      </div>
    </div>

    {eventos && eventos.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:28px;">
        {eventos.map((evento, idx) => (
          <a href={`/eventos/${evento.slug}`}
            class="reveal card-3d neon-card"
            style={`display:block;border-radius:24px;overflow:hidden;text-decoration:none;position:relative;transition-delay:${idx*80}ms;`}>

            <div style="position:relative;height:230px;overflow:hidden;background:linear-gradient(135deg,rgba(124,58,237,0.2),rgba(236,72,153,0.15));">
              {evento.imagen_url ? (
                <img src={evento.imagen_url} alt={evento.titulo}
                  style="width:100%;height:100%;object-fit:cover;transition:transform 0.7s ease;filter:brightness(0.65) saturate(1.3);"
                  class="card-img" />
              ) : (
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                  <div style="width:60px;height:60px;border:2px solid rgba(124,58,237,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <div style="width:24px;height:24px;background:linear-gradient(135deg,#7c3aed,#ec4899);border-radius:50%;"></div>
                  </div>
                </div>
              )}
              <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,20,0.98) 0%,rgba(10,10,20,0.2) 55%,transparent 100%);"></div>

              <div style="position:absolute;top:16px;right:16px;">
                <span style={`display:inline-block;padding:5px 14px;border-radius:100px;font-size:11px;font-weight:700;letter-spacing:0.5px;${evento.precio === 0 ? 'background:rgba(34,197,94,0.9);color:white;box-shadow:0 0 20px rgba(34,197,94,0.4);' : 'background:rgba(0,0,0,0.65);color:white;border:1px solid rgba(255,255,255,0.15);backdrop-filter:blur(10px);'}`}>
                  {evento.precio === 0 ? 'GRATIS' : `S/ ${evento.precio}`}
                </span>
              </div>

              <div style="position:absolute;bottom:16px;left:16px;right:16px;display:flex;align-items:center;justify-content:space-between;">
                <span style="background:rgba(124,58,237,0.8);backdrop-filter:blur(10px);color:white;font-size:11px;font-weight:600;padding:5px 12px;border-radius:8px;border:1px solid rgba(167,139,250,0.3);letter-spacing:0.5px;">
                  {new Date(evento.fecha).toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' })}
                </span>
                <span style="background:rgba(0,0,0,0.5);backdrop-filter:blur(10px);color:rgba(255,255,255,0.6);font-size:11px;padding:5px 12px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);">
                  {new Date(evento.fecha).toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'})}
                </span>
              </div>
            </div>

            <div style="padding:24px;">
              <h3 style="color:white;font-weight:800;font-size:19px;margin:0 0 10px;line-height:1.25;overflow:hidden;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;letter-spacing:-0.3px;font-family:'Space Grotesk',sans-serif;">
                {evento.titulo}
              </h3>
              <p style="color:rgba(255,255,255,0.32);font-size:13px;margin:0 0 20px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;line-height:1.65;">
                {evento.descripcion}
              </p>

              <div style="display:flex;align-items:center;justify-content:space-between;padding-top:16px;border-top:1px solid rgba(255,255,255,0.05);">
                <div style="display:flex;align-items:center;gap:6px;">
                  <div style="width:4px;height:4px;background:#a78bfa;border-radius:50%;"></div>
                  <span style="color:rgba(255,255,255,0.28);font-size:12px;">{evento.lugar}</span>
                </div>
                <div style="display:inline-flex;align-items:center;gap:6px;color:#a78bfa;font-size:12px;font-weight:700;background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.18);padding:6px 14px;border-radius:100px;transition:all 0.2s;">
                  Ver más
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="reveal" style="text-align:center;padding:140px 0;">
        <div style="width:80px;height:80px;border:1px solid rgba(124,58,237,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
          <div style="width:32px;height:32px;background:linear-gradient(135deg,rgba(124,58,237,0.4),rgba(236,72,153,0.4));border-radius:50%;"></div>
        </div>
        <p style="color:rgba(255,255,255,0.2);font-size:20px;font-weight:600;margin-bottom:8px;">No hay eventos publicados</p>
        <p style="color:rgba(255,255,255,0.1);font-size:14px;">Vuelve pronto para ver los próximos eventos</p>
      </div>
    )}
  </div>
</section>

<section id="como-funciona" style="background:linear-gradient(to bottom,#02020a,#06061a,#02020a);padding:120px 0;position:relative;overflow:hidden;">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:900px;height:900px;background:radial-gradient(circle,rgba(124,58,237,0.05),transparent 65%);border-radius:50%;pointer-events:none;"></div>

  <div style="max-width:1280px;margin:0 auto;padding:0 40px;position:relative;z-index:1;">
    <div class="reveal" style="text-align:center;margin-bottom:80px;">
      <div style="display:inline-flex;align-items:center;gap:12px;margin-bottom:16px;">
        <div style="width:24px;height:1px;background:linear-gradient(90deg,transparent,#7c3aed);"></div>
        <span style="color:#a78bfa;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:3px;">Proceso simple</span>
        <div style="width:24px;height:1px;background:linear-gradient(90deg,#ec4899,transparent);"></div>
      </div>
      <h2 style="font-size:clamp(36px,5vw,58px);font-weight:900;color:white;letter-spacing:-2px;font-family:'Space Grotesk',sans-serif;">
        ¿Cómo <span class="gradient-text">funciona</span>?
      </h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:2px;background:rgba(255,255,255,0.04);border-radius:24px;overflow:hidden;border:1px solid rgba(255,255,255,0.06);">
      {[
        { num:'01', title:'Explora', desc:'Navega por todos los eventos disponibles y encuentra el que más te guste.', color:'#7c3aed' },
        { num:'02', title:'Compra',  desc:'Selecciona la cantidad de entradas y completa el pago de forma segura.', color:'#ec4899' },
        { num:'03', title:'Recibe',  desc:'Obtén tu código QR único al instante, listo para presentar en la entrada.', color:'#6366f1' },
        { num:'04', title:'Disfruta',desc:'Presenta tu QR en la entrada y vive la experiencia al máximo.', color:'#f472b6' },
      ].map((item, i) => (
        <div class="reveal card-3d"
          style={`background:#02020a;padding:40px 32px;position:relative;overflow:hidden;transition-delay:${i*100}ms;`}>
          <div style={`position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,${item.color},transparent);`}></div>
          <div style={`font-size:72px;font-weight:900;color:${item.color};opacity:0.06;position:absolute;top:-10px;right:16px;line-height:1;font-family:'Space Grotesk',sans-serif;`}>{item.num}</div>
          <div style={`width:40px;height:40px;border:1px solid ${item.color}40;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;`}>
            <div style={`width:16px;height:16px;background:${item.color};border-radius:4px;opacity:0.8;`}></div>
          </div>
          <div style={`display:inline-block;background:${item.color}12;border:1px solid ${item.color}25;color:${item.color};font-size:10px;font-weight:700;padding:3px 10px;border-radius:100px;margin-bottom:14px;letter-spacing:1.5px;text-transform:uppercase;`}>Paso {item.num}</div>
          <h3 style="color:white;font-weight:800;font-size:20px;margin:0 0 10px;letter-spacing:-0.3px;font-family:'Space Grotesk',sans-serif;">{item.title}</h3>
          <p style="color:rgba(255,255,255,0.32);font-size:14px;line-height:1.7;margin:0;">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section style="background:#02020a;padding:120px 40px;text-align:center;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;pointer-events:none;">
    <div class="float" style="position:absolute;top:50%;left:15%;transform:translateY(-50%);width:500px;height:500px;background:radial-gradient(circle,rgba(124,58,237,0.07),transparent 65%);border-radius:50%;"></div>
    <div class="float2" style="position:absolute;top:50%;right:15%;transform:translateY(-50%);width:400px;height:400px;background:radial-gradient(circle,rgba(236,72,153,0.06),transparent 65%);border-radius:50%;"></div>
  </div>
  <div class="reveal" style="position:relative;z-index:1;max-width:640px;margin:0 auto;">
    <div style="display:inline-flex;align-items:center;gap:12px;margin-bottom:24px;padding:8px 20px;background:rgba(124,58,237,0.08);border:1px solid rgba(124,58,237,0.2);border-radius:100px;">
      <span style="width:6px;height:6px;background:#a78bfa;border-radius:50%;animation:pulse-ring 2s ease-out infinite;"></span>
      <span style="color:#c4b5fd;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;">Únete ahora</span>
    </div>
    <h2 style="font-size:clamp(36px,5vw,64px);font-weight:900;color:white;letter-spacing:-2px;margin-bottom:16px;line-height:1;font-family:'Space Grotesk',sans-serif;">
      ¿Listo para vivir<br/><span class="shimmer-text">la experiencia?</span>
    </h2>
    <p style="color:rgba(255,255,255,0.32);font-size:16px;margin-bottom:44px;line-height:1.7;">
      Miles de personas ya disfrutan de los mejores eventos con EventosApp.
    </p>
    <a href="#eventos" class="btn-primary"
      style="display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:700;font-size:15px;padding:18px 52px;border-radius:100px;text-decoration:none;box-shadow:0 8px 40px rgba(124,58,237,0.5),inset 0 1px 0 rgba(255,255,255,0.2);letter-spacing:0.5px;">
      Ver todos los eventos
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(el => {
      if (el.isIntersecting) (el.target as HTMLElement).classList.add('visible');
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  document.querySelectorAll('.card-3d').forEach(card => {
    card.addEventListener('mousemove', (e: any) => {
      const rect = (card as HTMLElement).getBoundingClientRect();
      const x = e.clientX - rect.left, y = e.clientY - rect.top;
      const cx = rect.width/2, cy = rect.height/2;
      const rotX = ((y-cy)/cy)*-10, rotY = ((x-cx)/cx)*10;
      (card as HTMLElement).style.transform = `perspective(1000px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateY(-10px) scale(1.02)`;
      (card as HTMLElement).style.boxShadow = `${rotY*-2}px ${rotX*2}px 50px rgba(124,58,237,0.2),0 25px 60px rgba(0,0,0,0.6)`;
    });
    card.addEventListener('mouseleave', () => {
      (card as HTMLElement).style.transform = '';
      (card as HTMLElement).style.boxShadow = '';
    });
    const img = card.querySelector('.card-img') as HTMLElement;
    if (img) {
      card.addEventListener('mouseenter', () => img.style.transform = 'scale(1.1)');
      card.addEventListener('mouseleave', () => img.style.transform = '');
    }
  });
</script>

</Layout>
