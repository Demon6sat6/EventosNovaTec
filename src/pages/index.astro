---
import Layout from '../layouts/Layout.astro';
import { createServerClient } from '../lib/supabase';
import HeroBackground from '../components/HeroBackground';

const db = createServerClient();
const { data: eventos } = await db
  .from('eventos')
  .select('*')
  .eq('publicado', true)
  .order('fecha', { ascending: true });
---
<Layout title="Inicio">

<!-- ═══════════════════════════════════════════
     HERO SECTION
═══════════════════════════════════════════ -->
<section style="position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;background:#02020a;">

  <!-- Three.js background -->
  <HeroBackground client:only="react" />

  <!-- Orbes de color -->
  <div style="position:absolute;inset:0;pointer-events:none;z-index:1;">
    <div class="float" style="position:absolute;top:-20%;left:-10%;width:600px;height:600px;background:radial-gradient(circle,rgba(124,58,237,0.12) 0%,transparent 70%);border-radius:50%;"></div>
    <div class="float2" style="position:absolute;bottom:-20%;right:-10%;width:500px;height:500px;background:radial-gradient(circle,rgba(236,72,153,0.1) 0%,transparent 70%);border-radius:50%;"></div>
    <div class="float3" style="position:absolute;top:40%;left:60%;width:300px;height:300px;background:radial-gradient(circle,rgba(99,102,241,0.08) 0%,transparent 70%);border-radius:50%;"></div>
  </div>

  <!-- Grid floor perspectiva -->
  <div style="position:absolute;bottom:0;left:0;right:0;height:45%;z-index:1;pointer-events:none;">
    <div class="grid-floor" style="width:100%;height:100%;"></div>
  </div>

  <!-- Scan line -->
  <div class="scan-line" style="position:absolute;inset:0;z-index:2;pointer-events:none;overflow:hidden;"></div>

  <!-- Contenido -->
  <div style="position:relative;z-index:10;max-width:1280px;margin:0 auto;padding:0 32px;width:100%;text-align:center;">

    <!-- Badge animado -->
    <div style="display:inline-flex;align-items:center;gap:10px;background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.35);padding:8px 20px;border-radius:100px;margin-bottom:36px;backdrop-filter:blur(10px);">
      <span style="width:8px;height:8px;background:#a78bfa;border-radius:50%;box-shadow:0 0 10px #a78bfa;animation:pulse-glow 2s ease-in-out infinite;"></span>
      <span style="color:#c4b5fd;font-size:13px;font-weight:600;letter-spacing:1px;text-transform:uppercase;">Sistema de eventos en vivo</span>
      <span style="width:8px;height:8px;background:#f472b6;border-radius:50%;box-shadow:0 0 10px #f472b6;animation:pulse-glow 2s ease-in-out infinite 1s;"></span>
    </div>

    <!-- Título principal con efecto glitch -->
    <div style="position:relative;margin-bottom:28px;">
      <h1 style="font-size:clamp(52px,9vw,110px);font-weight:900;line-height:0.95;letter-spacing:-4px;color:white;font-family:'Space Grotesk',sans-serif;">
        <span style="display:block;color:rgba(255,255,255,0.95);">VIVE LA</span>
        <span class="shimmer-text" style="display:block;font-size:clamp(60px,10vw,120px);">EXPERIENCIA</span>
      </h1>
      <!-- Glitch layers -->
      <div style="position:absolute;inset:0;pointer-events:none;overflow:hidden;">
        <h1 style="font-size:clamp(52px,9vw,110px);font-weight:900;line-height:0.95;letter-spacing:-4px;color:#7c3aed;opacity:0.3;position:absolute;top:0;left:0;right:0;animation:glitch 8s infinite 2s;font-family:'Space Grotesk',sans-serif;">
          <span style="display:block;">VIVE LA</span>
          <span style="display:block;font-size:clamp(60px,10vw,120px);">EXPERIENCIA</span>
        </h1>
      </div>
    </div>

    <p style="color:rgba(255,255,255,0.45);font-size:clamp(15px,2vw,20px);max-width:560px;margin:0 auto 48px;line-height:1.7;font-weight:400;">
      Descubre eventos únicos, compra entradas con tecnología QR y vive momentos que no olvidarás.
    </p>

    <!-- CTAs -->
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:80px;">
      <a href="#eventos" class="btn-future"
        style="display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:700;font-size:15px;padding:16px 36px;border-radius:100px;text-decoration:none;box-shadow:0 8px 32px rgba(124,58,237,0.4),inset 0 1px 0 rgba(255,255,255,0.2);">
        <span>Explorar eventos</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="#como-funciona" class="btn-future"
        style="display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.7);font-weight:600;font-size:15px;padding:16px 36px;border-radius:100px;text-decoration:none;backdrop-filter:blur(10px);">
        ¿Cómo funciona?
      </a>
    </div>

    <!-- Stats con efecto neon -->
    <div style="display:flex;gap:0;justify-content:center;flex-wrap:wrap;max-width:600px;margin:0 auto;">
      {[
        { num: eventos?.length ?? 0, label: 'Eventos activos', icon: '📅' },
        { num: 'QR', label: 'Entrada digital', icon: '🎟' },
        { num: '100%', label: 'Seguro', icon: '🔒' },
      ].map((s, i) => (
        <div style={`flex:1;min-width:140px;padding:20px;text-align:center;${i < 2 ? 'border-right:1px solid rgba(255,255,255,0.06);' : ''}`}>
          <p style="font-size:11px;color:rgba(255,255,255,0.25);text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;">{s.icon} {s.label}</p>
          <p style="font-size:32px;font-weight:900;background:linear-gradient(135deg,#a78bfa,#f472b6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">{s.num}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:32px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;z-index:10;">
    <span style="color:rgba(255,255,255,0.2);font-size:10px;letter-spacing:3px;text-transform:uppercase;">Scroll</span>
    <div style="width:1px;height:48px;background:linear-gradient(to bottom,rgba(124,58,237,0.6),transparent);animation:float 2s ease-in-out infinite;"></div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     EVENTOS SECTION
═══════════════════════════════════════════ -->
<section id="eventos" style="background:#02020a;padding:100px 0;position:relative;overflow:hidden;">

  <!-- Fondo decorativo -->
  <div style="position:absolute;inset:0;pointer-events:none;">
    <div class="cyber-grid" style="position:absolute;inset:0;opacity:0.4;"></div>
    <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(124,58,237,0.5),rgba(236,72,153,0.5),transparent);"></div>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 32px;position:relative;z-index:1;">

    <!-- Header sección -->
    <div class="reveal" style="margin-bottom:64px;display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;">
      <div>
        <div style="display:inline-flex;align-items:center;gap:8px;margin-bottom:12px;">
          <div style="width:24px;height:2px;background:linear-gradient(90deg,#7c3aed,#ec4899);"></div>
          <span style="color:#a78bfa;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:3px;">Próximos eventos</span>
        </div>
        <h2 style="font-size:clamp(32px,5vw,52px);font-weight:900;color:white;letter-spacing:-2px;line-height:1;">
          Elige tu <span class="gradient-text">experiencia</span>
        </h2>
      </div>
      <div style="background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.2);color:#a78bfa;font-size:13px;font-weight:600;padding:8px 16px;border-radius:100px;">
        {eventos?.length ?? 0} disponibles
      </div>
    </div>

    {eventos && eventos.length > 0 ? (
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:28px;">
        {eventos.map((evento, idx) => (
          <a href={`/eventos/${evento.slug}`}
            class="reveal card-3d neon-border"
            style={`display:block;border-radius:20px;overflow:hidden;text-decoration:none;position:relative;transition-delay:${idx * 80}ms;`}
            data-idx={idx}>

            <!-- Imagen con overlay holográfico -->
            <div style="position:relative;height:220px;overflow:hidden;">
              {evento.imagen_url ? (
                <img src={evento.imagen_url} alt={evento.titulo}
                  style="width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;filter:brightness(0.7) saturate(1.2);"
                  class="card-img" />
              ) : (
                <div class="holo" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                  <span style="font-size:72px;opacity:0.3;filter:drop-shadow(0 0 20px rgba(124,58,237,0.8));">🎭</span>
                </div>
              )}

              <!-- Overlay gradiente -->
              <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(10,10,24,0.95) 0%,rgba(10,10,24,0.3) 50%,transparent 100%);"></div>

              <!-- Holographic shimmer -->
              <div class="holo" style="position:absolute;inset:0;opacity:0.15;mix-blend-mode:screen;"></div>

              <!-- Badge precio -->
              <div style="position:absolute;top:14px;right:14px;">
                <span style={`display:inline-block;padding:5px 14px;border-radius:100px;font-size:12px;font-weight:700;backdrop-filter:blur(10px);${evento.precio === 0 ? 'background:rgba(34,197,94,0.85);color:white;box-shadow:0 0 20px rgba(34,197,94,0.4);' : 'background:rgba(0,0,0,0.6);color:white;border:1px solid rgba(255,255,255,0.2);'}`}>
                  {evento.precio === 0 ? '✦ GRATIS' : `S/ ${evento.precio}`}
                </span>
              </div>

              <!-- Fecha badge -->
              <div style="position:absolute;bottom:14px;left:14px;">
                <span style="background:rgba(124,58,237,0.85);backdrop-filter:blur(10px);color:white;font-size:11px;font-weight:600;padding:5px 12px;border-radius:8px;border:1px solid rgba(167,139,250,0.3);">
                  📅 {new Date(evento.fecha).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
                </span>
              </div>
            </div>

            <!-- Info -->
            <div style="padding:22px;background:linear-gradient(145deg,#0a0a18,#080812);">
              <h3 style="color:white;font-weight:800;font-size:18px;margin:0 0 8px;line-height:1.3;overflow:hidden;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;letter-spacing:-0.3px;">
                {evento.titulo}
              </h3>
              <p style="color:rgba(255,255,255,0.35);font-size:13px;margin:0 0 18px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;line-height:1.6;">
                {evento.descripcion}
              </p>

              <!-- Footer card -->
              <div style="display:flex;align-items:center;justify-content:space-between;padding-top:14px;border-top:1px solid rgba(255,255,255,0.05);">
                <span style="color:rgba(255,255,255,0.3);font-size:12px;display:flex;align-items:center;gap:5px;">
                  <span style="color:#a78bfa;">📍</span> {evento.lugar}
                </span>
                <span style="display:inline-flex;align-items:center;gap:6px;color:#a78bfa;font-size:12px;font-weight:700;background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.2);padding:5px 12px;border-radius:100px;transition:all 0.2s;">
                  Ver más
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="reveal" style="text-align:center;padding:120px 0;">
        <div style="font-size:80px;margin-bottom:20px;filter:drop-shadow(0 0 30px rgba(124,58,237,0.5));animation:float 4s ease-in-out infinite;">🎭</div>
        <p style="color:rgba(255,255,255,0.2);font-size:20px;font-weight:600;">No hay eventos publicados aún</p>
        <p style="color:rgba(255,255,255,0.1);font-size:14px;margin-top:8px;">Vuelve pronto para ver los próximos eventos</p>
      </div>
    )}
  </div>
</section>

<!-- ═══════════════════════════════════════════
     CÓMO FUNCIONA
═══════════════════════════════════════════ -->
<section id="como-funciona" style="background:linear-gradient(to bottom,#02020a,#05051a,#02020a);padding:100px 0;position:relative;overflow:hidden;">

  <div style="position:absolute;inset:0;pointer-events:none;">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:800px;height:800px;background:radial-gradient(circle,rgba(124,58,237,0.06),transparent 70%);border-radius:50%;"></div>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:0 32px;position:relative;z-index:1;">

    <div class="reveal" style="text-align:center;margin-bottom:72px;">
      <div style="display:inline-flex;align-items:center;gap:8px;margin-bottom:12px;">
        <div style="width:24px;height:2px;background:linear-gradient(90deg,#7c3aed,#ec4899);"></div>
        <span style="color:#a78bfa;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:3px;">Simple y rápido</span>
        <div style="width:24px;height:2px;background:linear-gradient(90deg,#ec4899,#7c3aed);"></div>
      </div>
      <h2 style="font-size:clamp(32px,5vw,52px);font-weight:900;color:white;letter-spacing:-2px;">
        ¿Cómo <span class="gradient-text">funciona</span>?
      </h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;">
      {[
        { step:'01', icon:'🔍', title:'Explora', desc:'Navega por todos los eventos disponibles y encuentra el que más te guste.', color:'#7c3aed' },
        { step:'02', icon:'🎟', title:'Compra', desc:'Selecciona la cantidad y completa el pago de forma segura.', color:'#ec4899' },
        { step:'03', icon:'📱', title:'Recibe tu QR', desc:'Obtén tu código QR único al instante, listo para usar.', color:'#6366f1' },
        { step:'04', icon:'🎉', title:'Disfruta', desc:'Presenta tu QR en la entrada y vive la experiencia.', color:'#f472b6' },
      ].map((item, i) => (
        <div class="reveal card-3d"
          style={`background:linear-gradient(145deg,#0a0a18,#080812);border:1px solid rgba(255,255,255,0.05);border-radius:20px;padding:32px 24px;position:relative;overflow:hidden;transition-delay:${i*100}ms;`}>

          <!-- Número decorativo -->
          <div style={`position:absolute;top:-10px;right:16px;font-size:80px;font-weight:900;color:${item.color};opacity:0.06;font-family:'Space Grotesk',sans-serif;line-height:1;`}>{item.step}</div>

          <!-- Ícono con glow -->
          <div style={`width:52px;height:52px;background:${item.color}18;border:1px solid ${item.color}40;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:20px;box-shadow:0 0 20px ${item.color}20;`}>
            {item.icon}
          </div>

          <!-- Step badge -->
          <div style={`display:inline-block;background:${item.color}15;border:1px solid ${item.color}30;color:${item.color};font-size:10px;font-weight:700;padding:3px 10px;border-radius:100px;margin-bottom:12px;letter-spacing:1px;`}>
            PASO {item.step}
          </div>

          <h3 style="color:white;font-weight:700;font-size:18px;margin:0 0 10px;letter-spacing:-0.3px;">{item.title}</h3>
          <p style="color:rgba(255,255,255,0.35);font-size:14px;line-height:1.7;margin:0;">{item.desc}</p>

          <!-- Línea inferior de color -->
          <div style={`position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,${item.color},transparent);opacity:0.4;`}></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     CTA FINAL
═══════════════════════════════════════════ -->
<section style="background:#02020a;padding:100px 32px;text-align:center;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;pointer-events:none;">
    <div class="float" style="position:absolute;top:50%;left:20%;transform:translateY(-50%);width:400px;height:400px;background:radial-gradient(circle,rgba(124,58,237,0.08),transparent 70%);border-radius:50%;"></div>
    <div class="float2" style="position:absolute;top:50%;right:20%;transform:translateY(-50%);width:350px;height:350px;background:radial-gradient(circle,rgba(236,72,153,0.06),transparent 70%);border-radius:50%;"></div>
  </div>
  <div class="reveal" style="position:relative;z-index:1;max-width:600px;margin:0 auto;">
    <h2 style="font-size:clamp(32px,5vw,56px);font-weight:900;color:white;letter-spacing:-2px;margin-bottom:16px;">
      ¿Listo para vivir<br/><span class="shimmer-text">la experiencia?</span>
    </h2>
    <p style="color:rgba(255,255,255,0.35);font-size:16px;margin-bottom:40px;line-height:1.7;">
      Únete a miles de personas que ya disfrutan de los mejores eventos con EventosApp.
    </p>
    <a href="#eventos" class="btn-future"
      style="display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:700;font-size:16px;padding:18px 48px;border-radius:100px;text-decoration:none;box-shadow:0 8px 40px rgba(124,58,237,0.5),inset 0 1px 0 rgba(255,255,255,0.2);">
      Ver todos los eventos
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<script>
  // Efecto 3D en cards con mouse
  document.querySelectorAll('.card-3d').forEach(card => {
    card.addEventListener('mousemove', (e: any) => {
      const rect = (card as HTMLElement).getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const cx = rect.width / 2;
      const cy = rect.height / 2;
      const rotX = ((y - cy) / cy) * -10;
      const rotY = ((x - cx) / cx) * 10;
      (card as HTMLElement).style.transform = `perspective(1000px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateY(-10px) scale(1.02)`;
      (card as HTMLElement).style.boxShadow = `${rotY * -2}px ${rotX * 2}px 40px rgba(124,58,237,0.2), 0 20px 60px rgba(0,0,0,0.5)`;
    });
    card.addEventListener('mouseleave', () => {
      (card as HTMLElement).style.transform = '';
      (card as HTMLElement).style.boxShadow = '';
    });
    // Zoom imagen al hover
    const img = card.querySelector('.card-img') as HTMLElement;
    if (img) {
      card.addEventListener('mouseenter', () => img.style.transform = 'scale(1.08)');
      card.addEventListener('mouseleave', () => img.style.transform = '');
    }
  });
</script>

</Layout>
