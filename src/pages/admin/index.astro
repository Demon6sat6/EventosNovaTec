---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createServerClient } from '../../lib/supabase';

const db = createServerClient();

const [
  { count: totalEventos },
  { count: totalEntradas },
  { data: ventas },
  { count: totalAsistentes },
] = await Promise.all([
  db.from('eventos').select('*', { count: 'exact', head: true }),
  db.from('entradas').select('*', { count: 'exact', head: true }).in('estado', ['pagado', 'asistio']),
  db.from('entradas').select('total').in('estado', ['pagado', 'asistio']),
  db.from('entradas').select('*', { count: 'exact', head: true }).eq('estado', 'asistio'),
]);

const totalVentas = ventas?.reduce((s, e) => s + (e.total ?? 0), 0) ?? 0;

const { data: ultimasEntradas } = await db
  .from('entradas')
  .select('*, evento:eventos(titulo)')
  .in('estado', ['pagado', 'asistio'])
  .order('created_at', { ascending: false })
  .limit(6);

const stats = [
  { label: 'Eventos activos',    value: totalEventos ?? 0,          icon: '📅', color: '#7c3aed', bg: 'rgba(124,58,237,0.12)',  border: 'rgba(124,58,237,0.25)' },
  { label: 'Entradas vendidas',  value: totalEntradas ?? 0,         icon: '🎟', color: '#ec4899', bg: 'rgba(236,72,153,0.12)',  border: 'rgba(236,72,153,0.25)' },
  { label: 'Asistentes',         value: totalAsistentes ?? 0,       icon: '👥', color: '#6366f1', bg: 'rgba(99,102,241,0.12)',  border: 'rgba(99,102,241,0.25)' },
  { label: 'Ingresos totales',   value: `S/ ${totalVentas.toFixed(2)}`, icon: '💰', color: '#22c55e', bg: 'rgba(34,197,94,0.12)', border: 'rgba(34,197,94,0.25)' },
];
---
<AdminLayout title="Dashboard">

  <!-- Stats grid -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:32px;">
    {stats.map(s => (
      <div style={`background:${s.bg};border:1px solid ${s.border};border-radius:16px;padding:20px 22px;position:relative;overflow:hidden;`}>
        <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.1),transparent);"></div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
          <span style="font-size:22px;">{s.icon}</span>
          <span style={`font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:${s.color};background:rgba(255,255,255,0.05);padding:3px 8px;border-radius:100px;`}>Total</span>
        </div>
        <p style={`font-size:32px;font-weight:900;color:${s.color};line-height:1;margin-bottom:6px;`}>{s.value}</p>
        <p style="color:rgba(255,255,255,0.35);font-size:12px;">{s.label}</p>
      </div>
    ))}
  </div>

  <!-- Accesos rápidos + últimas compras -->
  <div style="display:grid;grid-template-columns:260px 1fr;gap:20px;align-items:start;">

    <!-- Accesos rápidos -->
    <div>
      <p style="color:rgba(255,255,255,0.25);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;">Accesos rápidos</p>
      <div style="display:flex;flex-direction:column;gap:8px;">
        {[
          { href:'/admin/eventos/nuevo', icon:'➕', label:'Nuevo evento',    desc:'Crear y publicar',    color:'#7c3aed' },
          { href:'/admin/checkin',       icon:'📷', label:'Check-in QR',    desc:'Validar entradas',    color:'#22c55e' },
          { href:'/admin/reportes',      icon:'📊', label:'Ver reportes',   desc:'Ventas y estadísticas', color:'#f59e0b' },
          { href:'/admin/participantes', icon:'👥', label:'Participantes',  desc:'Lista de asistentes', color:'#6366f1' },
        ].map(item => (
          <a href={item.href}
            style={`display:flex;align-items:center;gap:12px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:12px 14px;text-decoration:none;transition:all 0.2s;`}
            onmouseover={`this.style.background='rgba(255,255,255,0.06)';this.style.borderColor='${item.color}40';`}
            onmouseout="this.style.background='rgba(255,255,255,0.03)';this.style.borderColor='rgba(255,255,255,0.06)';">
            <span style={`width:36px;height:36px;background:${item.color}18;border:1px solid ${item.color}30;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;`}>{item.icon}</span>
            <div style="min-width:0;">
              <p style="color:white;font-size:13px;font-weight:600;">{item.label}</p>
              <p style="color:rgba(255,255,255,0.3);font-size:11px;">{item.desc}</p>
            </div>
            <span style="margin-left:auto;color:rgba(255,255,255,0.15);font-size:14px;">→</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Últimas compras -->
    <div>
      <p style="color:rgba(255,255,255,0.25);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:12px;">Últimas compras</p>
      <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:16px;overflow:hidden;">
        {ultimasEntradas && ultimasEntradas.length > 0 ? (
          <div>
            {ultimasEntradas.map((e, i) => (
              <div style={`display:flex;align-items:center;gap:14px;padding:14px 18px;${i < ultimasEntradas.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.04);' : ''}`}>
                <div style="width:36px;height:36px;background:linear-gradient(135deg,rgba(124,58,237,0.3),rgba(236,72,153,0.3));border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0;color:white;">
                  {e.nombre.charAt(0).toUpperCase()}
                </div>
                <div style="flex:1;min-width:0;">
                  <p style="color:white;font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{e.nombre}</p>
                  <p style="color:rgba(255,255,255,0.3);font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{(e.evento as any)?.titulo ?? '—'}</p>
                </div>
                <div style="text-align:right;flex-shrink:0;">
                  <p style="color:white;font-size:13px;font-weight:700;">S/ {e.total?.toFixed(2)}</p>
                  <p style="color:rgba(255,255,255,0.2);font-size:11px;">{new Date(e.created_at).toLocaleDateString('es-ES')}</p>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div style="text-align:center;padding:48px 24px;">
            <p style="font-size:36px;margin-bottom:8px;opacity:0.3;">🛒</p>
            <p style="color:rgba(255,255,255,0.2);font-size:13px;">No hay compras aún</p>
          </div>
        )}
      </div>
    </div>

  </div>

</AdminLayout>
