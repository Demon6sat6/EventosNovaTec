---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createServerClient } from '../../lib/supabase';
import { getSessionUser } from '../../lib/auth';

const currentUser = getSessionUser(Astro.cookies);
const db = createServerClient();

const { data: usuarios } = await db
  .from('admin_users')
  .select('id, email, nombre, rol, activo, created_at')
  .order('created_at', { ascending: true });

let successMsg = Astro.url.searchParams.get('ok') ?? '';
let errorMsg   = Astro.url.searchParams.get('err') ?? '';
---
<AdminLayout title="Usuarios">

  <div style="max-width:860px;display:flex;flex-direction:column;gap:20px;">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <div>
        <p style="color:rgba(255,255,255,0.3);font-size:13px;">Gestiona los accesos al panel de administración</p>
      </div>
      {currentUser?.rol === 'superadmin' && (
        <button onclick="document.getElementById('modal-nuevo').style.display='flex'"
          style="background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:700;font-size:13px;padding:10px 18px;border-radius:10px;border:none;cursor:pointer;display:flex;align-items:center;gap:8px;">
          ➕ Nuevo usuario
        </button>
      )}
    </div>

    {successMsg && (
      <div style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);color:#4ade80;font-size:13px;padding:12px 16px;border-radius:12px;display:flex;align-items:center;gap:8px;">
        ✅ {successMsg}
      </div>
    )}
    {errorMsg && (
      <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#f87171;font-size:13px;padding:12px 16px;border-radius:12px;display:flex;align-items:center;gap:8px;">
        ⚠️ {errorMsg}
      </div>
    )}

    <!-- Tabla de usuarios -->
    <div style="background:#0d0d1c;border:1px solid rgba(255,255,255,0.06);border-radius:20px;overflow:hidden;">
      <div style="padding:18px 22px;border-bottom:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:10px;">
        <span style="font-size:16px;">👥</span>
        <span style="color:white;font-weight:700;font-size:15px;">Administradores</span>
        <span style="margin-left:auto;background:rgba(124,58,237,0.15);border:1px solid rgba(124,58,237,0.25);color:#a78bfa;font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px;">{usuarios?.length ?? 0}</span>
      </div>

      {usuarios && usuarios.length > 0 ? (
        <div>
          {usuarios.map((u, i) => (
            <div style={`display:flex;align-items:center;gap:14px;padding:14px 22px;${i < usuarios.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,0.04);' : ''}`}>
              <div style="width:38px;height:38px;background:linear-gradient(135deg,rgba(124,58,237,0.4),rgba(236,72,153,0.4));border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;flex-shrink:0;color:white;">
                {(u.nombre ?? u.email).charAt(0).toUpperCase()}
              </div>
              <div style="flex:1;min-width:0;">
                <p style="color:white;font-size:13px;font-weight:600;">{u.nombre ?? '—'}</p>
                <p style="color:rgba(255,255,255,0.35);font-size:12px;">{u.email}</p>
              </div>
              <span style={`font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px;border:1px solid;${u.rol === 'superadmin' ? 'color:#f472b6;background:rgba(244,114,182,0.1);border-color:rgba(244,114,182,0.25);' : 'color:#a78bfa;background:rgba(167,139,250,0.1);border-color:rgba(167,139,250,0.25);'}`}>
                {u.rol}
              </span>
              <span style={`font-size:11px;font-weight:600;padding:3px 10px;border-radius:100px;border:1px solid;${u.activo ? 'color:#4ade80;background:rgba(74,222,128,0.08);border-color:rgba(74,222,128,0.2);' : 'color:#f87171;background:rgba(248,113,113,0.08);border-color:rgba(248,113,113,0.2);'}`}>
                {u.activo ? 'Activo' : 'Inactivo'}
              </span>
              {currentUser?.rol === 'superadmin' && u.id !== currentUser.id && (
                <div style="display:flex;gap:6px;flex-shrink:0;">
                  <button
                    onclick={`openEditModal('${u.id}','${u.email}','${u.nombre ?? ''}','${u.rol}')`}
                    style="background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.25);color:#818cf8;font-size:12px;padding:6px 12px;border-radius:8px;cursor:pointer;">
                    ✏️ Editar
                  </button>
                  <form method="POST" action="/api/admin/usuarios/toggle" style="display:inline;">
                    <input type="hidden" name="id" value={u.id} />
                    <input type="hidden" name="activo" value={String(!u.activo)} />
                    <button type="submit"
                      style={`background:${u.activo ? 'rgba(239,68,68,0.08)' : 'rgba(34,197,94,0.08)'};border:1px solid ${u.activo ? 'rgba(239,68,68,0.2)' : 'rgba(34,197,94,0.2)'};color:${u.activo ? '#f87171' : '#4ade80'};font-size:12px;padding:6px 12px;border-radius:8px;cursor:pointer;`}>
                      {u.activo ? '🚫 Desactivar' : '✅ Activar'}
                    </button>
                  </form>
                </div>
              )}
              {u.id === currentUser?.id && (
                <span style="color:rgba(255,255,255,0.2);font-size:12px;padding:6px 12px;">Tú</span>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div style="text-align:center;padding:48px 24px;">
          <p style="font-size:36px;margin-bottom:8px;opacity:0.3;">👤</p>
          <p style="color:rgba(255,255,255,0.2);font-size:13px;">No hay usuarios aún</p>
        </div>
      )}
    </div>

  </div>

  <!-- Modal: Nuevo usuario -->
  <div id="modal-nuevo" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:100;align-items:center;justify-content:center;padding:24px;">
    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,0.1);border-radius:20px;padding:28px;width:100%;max-width:440px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 style="color:white;font-weight:700;font-size:16px;">Nuevo usuario</h3>
        <button onclick="document.getElementById('modal-nuevo').style.display='none'"
          style="background:none;border:none;color:rgba(255,255,255,0.3);font-size:20px;cursor:pointer;line-height:1;">×</button>
      </div>
      <form method="POST" action="/api/admin/usuarios/crear" style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Nombre</label>
          <input type="text" name="nombre" placeholder="Nombre completo" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Correo electrónico</label>
          <input type="email" name="email" required placeholder="usuario@ejemplo.com" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Contraseña</label>
          <input type="password" name="password" required placeholder="Mínimo 8 caracteres" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Rol</label>
          <select name="rol" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;">
            <option value="admin" style="background:#0f0f1a;">Admin</option>
            <option value="superadmin" style="background:#0f0f1a;">Superadmin</option>
          </select>
        </div>
        <div style="display:flex;gap:10px;margin-top:4px;">
          <button type="button" onclick="document.getElementById('modal-nuevo').style.display='none'"
            style="flex:1;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);font-size:13px;padding:11px;border-radius:10px;cursor:pointer;font-family:inherit;">
            Cancelar
          </button>
          <button type="submit"
            style="flex:1;background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:700;font-size:13px;padding:11px;border-radius:10px;border:none;cursor:pointer;font-family:inherit;">
            Crear usuario
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Editar usuario -->
  <div id="modal-editar" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:100;align-items:center;justify-content:center;padding:24px;">
    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,0.1);border-radius:20px;padding:28px;width:100%;max-width:440px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 style="color:white;font-weight:700;font-size:16px;">Editar usuario</h3>
        <button onclick="document.getElementById('modal-editar').style.display='none'"
          style="background:none;border:none;color:rgba(255,255,255,0.3);font-size:20px;cursor:pointer;line-height:1;">×</button>
      </div>
      <form method="POST" action="/api/admin/usuarios/editar" style="display:flex;flex-direction:column;gap:14px;">
        <input type="hidden" id="edit-id" name="id" />
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Nombre</label>
          <input type="text" id="edit-nombre" name="nombre" placeholder="Nombre completo" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Correo electrónico</label>
          <input type="email" id="edit-email" name="email" required style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Nueva contraseña <span style="color:rgba(255,255,255,0.2);font-weight:400;">(dejar vacío para no cambiar)</span></label>
          <input type="password" name="password" placeholder="••••••••" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Rol</label>
          <select id="edit-rol" name="rol" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;">
            <option value="admin" style="background:#0f0f1a;">Admin</option>
            <option value="superadmin" style="background:#0f0f1a;">Superadmin</option>
          </select>
        </div>
        <div style="display:flex;gap:10px;margin-top:4px;">
          <button type="button" onclick="document.getElementById('modal-editar').style.display='none'"
            style="flex:1;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);font-size:13px;padding:11px;border-radius:10px;cursor:pointer;font-family:inherit;">
            Cancelar
          </button>
          <button type="submit"
            style="flex:1;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:white;font-weight:700;font-size:13px;padding:11px;border-radius:10px;border:none;cursor:pointer;font-family:inherit;">
            Guardar cambios
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function openEditModal(id: string, email: string, nombre: string, rol: string) {
      (document.getElementById('edit-id') as HTMLInputElement).value = id;
      (document.getElementById('edit-email') as HTMLInputElement).value = email;
      (document.getElementById('edit-nombre') as HTMLInputElement).value = nombre;
      (document.getElementById('edit-rol') as HTMLSelectElement).value = rol;
      document.getElementById('modal-editar')!.style.display = 'flex';
    }
  </script>

</AdminLayout>
