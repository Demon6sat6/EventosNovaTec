---
import AdminLayout from '../../layouts/AdminLayout.astro';

const adminEmail = import.meta.env.ADMIN_EMAIL ?? 'admin@eventosapp.com';
---
<AdminLayout title="Mi Perfil">
  <div style="max-width:640px;display:flex;flex-direction:column;gap:20px;">

    <!-- Info de cuenta -->
    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,0.05);border-radius:16px;padding:24px;">
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:8px;">
        <div style="width:64px;height:64px;background:linear-gradient(135deg,#7c3aed,#ec4899);border-radius:16px;display:flex;align-items:center;justify-content:center;color:white;font-size:24px;font-weight:900;box-shadow:0 8px 24px rgba(124,58,237,0.3);flex-shrink:0;">
          {adminEmail.charAt(0).toUpperCase()}
        </div>
        <div>
          <h2 style="color:white;font-weight:700;font-size:16px;margin:0 0 2px;">{adminEmail}</h2>
          <p style="color:rgba(255,255,255,0.3);font-size:13px;margin:0 0 6px;">Administrador</p>
          <span style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);color:#4ade80;font-size:11px;padding:3px 10px;border-radius:100px;">
            <span style="width:6px;height:6px;background:#4ade80;border-radius:50%;"></span>
            Sesión activa
          </span>
        </div>
      </div>
    </div>

    <!-- Credenciales -->
    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,0.05);border-radius:16px;padding:24px;">
      <h3 style="color:white;font-weight:700;font-size:14px;margin:0 0 16px;">Credenciales de acceso</h3>

      <div style="display:flex;flex-direction:column;gap:10px;">
        <div style="display:flex;align-items:center;justify-content:space-between;background:#080810;border:1px solid rgba(255,255,255,0.05);border-radius:12px;padding:12px 16px;">
          <div>
            <p style="color:rgba(255,255,255,0.3);font-size:11px;margin:0 0 2px;">Correo electrónico</p>
            <p style="color:white;font-size:13px;font-weight:500;margin:0;">{adminEmail}</p>
          </div>
          <span style="color:rgba(255,255,255,0.2);font-size:11px;">Email</span>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;background:#080810;border:1px solid rgba(255,255,255,0.05);border-radius:12px;padding:12px 16px;">
          <div>
            <p style="color:rgba(255,255,255,0.3);font-size:11px;margin:0 0 2px;">Contraseña</p>
            <p style="color:white;font-size:13px;font-weight:500;letter-spacing:4px;margin:0;">••••••••</p>
          </div>
          <span style="color:rgba(255,255,255,0.2);font-size:11px;">Password</span>
        </div>
      </div>

      <p style="color:rgba(255,255,255,0.2);font-size:11px;margin:14px 0 0;">Para cambiar las credenciales, actualiza las variables de entorno en el servidor.</p>
    </div>

    <!-- Cerrar sesión -->
    <div style="background:#0f0f1a;border:1px solid rgba(239,68,68,0.1);border-radius:16px;padding:24px;">
      <h3 style="color:white;font-weight:700;font-size:14px;margin:0 0 4px;">Cerrar sesión</h3>
      <p style="color:rgba(255,255,255,0.3);font-size:13px;margin:0 0 16px;">Tu sesión expira automáticamente en 8 horas.</p>
      <form method="POST" action="/api/auth/logout">
        <button type="submit"
          style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#f87171;font-weight:600;padding:10px 20px;border-radius:10px;font-size:13px;cursor:pointer;transition:background 0.2s;"
          onmouseover="this.style.background='rgba(239,68,68,0.2)'"
          onmouseout="this.style.background='rgba(239,68,68,0.1)'">
          ⏻ Cerrar sesión
        </button>
      </form>
    </div>

  </div>
</AdminLayout>
