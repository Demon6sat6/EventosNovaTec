---
import AdminLayout from '../../layouts/AdminLayout.astro';

const adminEmail = import.meta.env.ADMIN_EMAIL ?? 'admin@eventosapp.com';
---
<AdminLayout title="Mi Perfil">
  <div class="max-w-2xl space-y-6">

    <!-- Info de cuenta -->
    <div class="bg-[#0f0f1a] border border-white/5 rounded-2xl p-6">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-violet-500 to-pink-500 rounded-2xl flex items-center justify-center text-white text-2xl font-black shadow-lg shadow-violet-500/30">
          {adminEmail.charAt(0).toUpperCase()}
        </div>
        <div>
          <h2 class="text-white font-bold text-lg">{adminEmail}</h2>
          <p class="text-white/30 text-sm">Administrador</p>
          <span class="inline-flex items-center gap-1.5 bg-green-500/10 border border-green-500/20 text-green-400 text-xs px-2.5 py-1 rounded-full mt-1">
            <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
            Sesión activa
          </span>
        </div>
      </div>
    </div>

    <!-- Credenciales -->
    <div class="bg-[#0f0f1a] border border-white/5 rounded-2xl p-6 space-y-4">
      <h3 class="text-white font-bold mb-1">Credenciales de acceso</h3>

      <div class="space-y-3">
        <div class="flex items-center justify-between bg-[#080810] border border-white/5 rounded-xl px-4 py-3">
          <div>
            <p class="text-white/30 text-xs mb-0.5">Correo electrónico</p>
            <p class="text-white text-sm font-medium">{adminEmail}</p>
          </div>
          <span class="text-white/20 text-xs">Email</span>
        </div>

        <div class="flex items-center justify-between bg-[#080810] border border-white/5 rounded-xl px-4 py-3">
          <div>
            <p class="text-white/30 text-xs mb-0.5">Contraseña</p>
            <p class="text-white text-sm font-medium tracking-widest">••••••••</p>
          </div>
          <span class="text-white/20 text-xs">Password</span>
        </div>
      </div>

      <p class="text-white/20 text-xs">Para cambiar las credenciales, actualiza las variables de entorno en el servidor.</p>
    </div>

    <!-- Cerrar sesión -->
    <div class="bg-[#0f0f1a] border border-red-500/10 rounded-2xl p-6">
      <h3 class="text-white font-bold mb-1">Cerrar sesión</h3>
      <p class="text-white/30 text-sm mb-4">Tu sesión expira automáticamente en 8 horas.</p>
      <form method="POST" action="/api/auth/logout">
        <button type="submit"
          class="bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 font-semibold px-6 py-2.5 rounded-xl text-sm transition">
          ⏻ Cerrar sesión
        </button>
      </form>
    </div>

  </div>
</AdminLayout>
