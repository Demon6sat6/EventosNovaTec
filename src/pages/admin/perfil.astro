---
import AdminLayout from '../../layouts/AdminLayout.astro';

const adminEmail = import.meta.env.ADMIN_EMAIL ?? 'admin@eventosapp.com';
---
<AdminLayout title="Mi Perfil">
  <div class="max-w-2xl space-y-6">

    <!-- Info de cuenta -->
    <div class="bg-[#0f0f1a] border border-white/5 rounded-2xl p-6">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-violet-500 to-pink-500 rounded-2xl flex items-center justify-center text-white text-2xl font-black shadow-lg shadow-violet-500/30">
          {adminEmail.charAt(0).toUpperCase()}
        </div>
        <div>
          <h2 class="text-white font-bold text-lg">{adminEmail}</h2>
          <p class="text-white/30 text-sm">Administrador</p>
          <span class="inline-flex items-center gap-1.5 bg-green-500/10 border border-green-500/20 text-green-400 text-xs px-2.5 py-1 rounded-full mt-1">
            <span class="w-1.5 h-1.5 bg-green-400 rounded-full"></span>
            Sesión activa
          </span>
        </div>
      </div>
    </div>

    <!-- Cambiar credenciales -->
    <div class="bg-[#0f0f1a] border border-white/5 rounded-2xl p-6">
      <h3 class="text-white font-bold mb-1">Cambiar credenciales</h3>
      <p class="text-white/30 text-sm mb-5">
        Las credenciales se gestionan desde el archivo <code class="bg-white/5 px-1.5 py-0.5 rounded text-violet-300">.env</code> del proyecto.
      </p>

      <div class="bg-[#080810] border border-white/5 rounded-xl p-4 font-mono text-sm space-y-1">
        <p class="text-white/20 text-xs mb-2"># .env</p>
        <p><span class="text-violet-400">ADMIN_EMAIL</span><span class="text-white/40">=</span><span class="text-green-400">{adminEmail}</span></p>
        <p><span class="text-violet-400">ADMIN_PASSWORD</span><span class="text-white/40">=</span><span class="text-white/30">••••••••</span></p>
      </div>

      <p class="text-white/20 text-xs mt-3">
        Edita el archivo <code class="text-violet-300">.env</code>, cambia los valores y reinicia el servidor para aplicar los cambios.
      </p>
    </div>

    <!-- Cerrar sesión -->
    <div class="bg-[#0f0f1a] border border-red-500/10 rounded-2xl p-6">
      <h3 class="text-white font-bold mb-1">Cerrar sesión</h3>
      <p class="text-white/30 text-sm mb-4">Tu sesión expira automáticamente en 8 horas.</p>
      <form method="POST" action="/api/auth/logout">
        <button type="submit"
          class="bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 font-semibold px-6 py-2.5 rounded-xl text-sm transition">
          ⏻ Cerrar sesión
        </button>
      </form>
    </div>

  </div>
</AdminLayout>
