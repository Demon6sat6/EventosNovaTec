---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSessionUser } from '../../lib/auth';

const currentUser = getSessionUser(Astro.cookies);
const successMsg = Astro.url.searchParams.get('ok') ?? '';
const errorMsg   = Astro.url.searchParams.get('err') ?? '';
---
<AdminLayout title="Mi Perfil">
  <div style="max-width:640px;display:flex;flex-direction:column;gap:20px;">

    {successMsg && (
      <div style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);color:#4ade80;font-size:13px;padding:12px 16px;border-radius:12px;display:flex;align-items:center;gap:8px;">
        ✅ {successMsg}
      </div>
    )}
    {errorMsg && (
      <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#f87171;font-size:13px;padding:12px 16px;border-radius:12px;display:flex;align-items:center;gap:8px;">
        ⚠️ {errorMsg}
      </div>
    )}

    <!-- Info de cuenta -->
    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,0.05);border-radius:16px;padding:24px;">
      <div style="display:flex;align-items:center;gap:16px;">
        <div style="width:64px;height:64px;background:linear-gradient(135deg,#7c3aed,#ec4899);border-radius:16px;display:flex;align-items:center;justify-content:center;color:white;font-size:24px;font-weight:900;box-shadow:0 8px 24px rgba(124,58,237,0.3);flex-shrink:0;">
          {(currentUser?.nombre ?? currentUser?.email ?? 'A').charAt(0).toUpperCase()}
        </div>
        <div>
          <h2 style="color:white;font-weight:700;font-size:16px;margin:0 0 2px;">{currentUser?.nombre ?? currentUser?.email}</h2>
          <p style="color:rgba(255,255,255,0.3);font-size:13px;margin:0 0 6px;">{currentUser?.email}</p>
          <span style={`display:inline-flex;align-items:center;gap:6px;font-size:11px;padding:3px 10px;border-radius:100px;border:1px solid;${currentUser?.rol === 'superadmin' ? 'background:rgba(244,114,182,0.1);border-color:rgba(244,114,182,0.25);color:#f472b6;' : 'background:rgba(167,139,250,0.1);border-color:rgba(167,139,250,0.25);color:#a78bfa;'}`}>
            {currentUser?.rol}
          </span>
        </div>
      </div>
    </div>

    <!-- Cambiar credenciales -->
    <div style="background:#0f0f1a;border:1px solid rgba(255,255,255,0.05);border-radius:16px;padding:24px;">
      <h3 style="color:white;font-weight:700;font-size:14px;margin:0 0 16px;">Cambiar credenciales</h3>
      <form method="POST" action="/api/admin/perfil/actualizar" style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Nombre</label>
          <input type="text" name="nombre" value={currentUser?.nombre ?? ''} placeholder="Tu nombre"
            style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Correo electrónico</label>
          <input type="email" name="email" value={currentUser?.email ?? ''} required
            style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Contraseña actual</label>
          <input type="password" name="current_password" required placeholder="••••••••"
            style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Nueva contraseña <span style="color:rgba(255,255,255,0.2);font-weight:400;">(dejar vacío para no cambiar)</span></label>
          <input type="password" name="new_password" placeholder="Mínimo 8 caracteres"
            style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:11px 14px;font-size:13px;outline:none;font-family:inherit;" />
        </div>
        <button type="submit"
          style="background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:700;font-size:13px;padding:12px;border-radius:10px;border:none;cursor:pointer;font-family:inherit;margin-top:4px;">
          Guardar cambios
        </button>
      </form>
    </div>

    <!-- Cerrar sesión -->
    <div style="background:#0f0f1a;border:1px solid rgba(239,68,68,0.1);border-radius:16px;padding:24px;">
      <h3 style="color:white;font-weight:700;font-size:14px;margin:0 0 4px;">Cerrar sesión</h3>
      <p style="color:rgba(255,255,255,0.3);font-size:13px;margin:0 0 16px;">Tu sesión expira automáticamente en 8 horas.</p>
      <form method="POST" action="/api/auth/logout">
        <button type="submit"
          style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);color:#f87171;font-weight:600;padding:10px 20px;border-radius:10px;font-size:13px;cursor:pointer;font-family:inherit;"
          onmouseover="this.style.background='rgba(239,68,68,0.2)'"
          onmouseout="this.style.background='rgba(239,68,68,0.1)'">
          ⏻ Cerrar sesión
        </button>
      </form>
    </div>

  </div>
</AdminLayout>
