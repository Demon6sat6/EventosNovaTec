---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createServerClient } from '../../lib/supabase';

const db = createServerClient();
const eventoId = Astro.url.searchParams.get('evento');
const { data: eventos } = await db.from('eventos').select('id, titulo').order('fecha', { ascending: false });

let entradas: any[] = [];
let eventoActual: any = null;

if (eventoId) {
  const [{ data }, { data: ev }] = await Promise.all([
    db.from('entradas').select('*').eq('evento_id', eventoId).order('created_at', { ascending: false }),
    db.from('eventos').select('titulo').eq('id', eventoId).single(),
  ]);
  entradas = data ?? [];
  eventoActual = ev;
}

const estadoStyle: Record<string, string> = {
  pagado:    'background:rgba(124,58,237,0.12);color:#c4b5fd;border:1px solid rgba(124,58,237,0.25);',
  asistio:   'background:rgba(34,197,94,0.12);color:#4ade80;border:1px solid rgba(34,197,94,0.25);',
  pendiente: 'background:rgba(245,158,11,0.12);color:#fbbf24;border:1px solid rgba(245,158,11,0.25);',
  cancelado: 'background:rgba(239,68,68,0.12);color:#f87171;border:1px solid rgba(239,68,68,0.25);',
};
---
<AdminLayout title="Participantes">

  <!-- Selector de evento -->
  <form style="display:flex;gap:12px;align-items:flex-end;margin-bottom:24px;">
    <div style="flex:1;">
      <label style="display:block;color:rgba(255,255,255,0.3);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;">Seleccionar evento</label>
      <select name="evento"
        style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:10px 14px;font-size:13px;outline:none;font-family:inherit;color-scheme:dark;">
        <option value="">-- Selecciona un evento --</option>
        {eventos?.map(ev => (
          <option value={ev.id} selected={ev.id === eventoId}>{ev.titulo}</option>
        ))}
      </select>
    </div>
    <button type="submit"
      style="background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:600;font-size:13px;padding:10px 20px;border-radius:10px;border:none;cursor:pointer;font-family:inherit;white-space:nowrap;">
      Ver participantes
    </button>
  </form>

  {eventoId && (
    <div style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:16px;overflow:hidden;">
      <!-- Header -->
      <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;border-bottom:1px solid rgba(255,255,255,0.06);">
        <p style="color:white;font-weight:600;font-size:14px;">{eventoActual?.titulo}</p>
        <span style="background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.4);font-size:11px;padding:3px 10px;border-radius:100px;">{entradas.length} registros</span>
      </div>

      <!-- Tabla -->
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="border-bottom:1px solid rgba(255,255,255,0.05);">
              {['Nombre','Email','Cant.','Total','Estado','Fecha','Acciones'].map(h => (
                <th style="padding:10px 16px;text-align:left;color:rgba(255,255,255,0.2);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;white-space:nowrap;">{h}</th>
              ))}
            </tr>
          </thead>
          <tbody id="tabla-participantes">
            {entradas.map(e => (
              <tr data-id={e.id} style="border-bottom:1px solid rgba(255,255,255,0.03);transition:background 0.15s;"
                onmouseover="this.style.background='rgba(255,255,255,0.02)'" onmouseout="this.style.background='transparent'">
                <td style="padding:12px 16px;">
                  <span class="campo-nombre" style="color:white;font-weight:500;">{e.nombre}</span>
                </td>
                <td style="padding:12px 16px;">
                  <span class="campo-email" style="color:rgba(255,255,255,0.4);">{e.email}</span>
                </td>
                <td style="padding:12px 16px;">
                  <span class="campo-cantidad" style="color:rgba(255,255,255,0.5);">{e.cantidad}</span>
                </td>
                <td style="padding:12px 16px;color:white;font-weight:600;">S/ {e.total?.toFixed(2)}</td>
                <td style="padding:12px 16px;">
                  <span class="campo-estado" style={`display:inline-block;padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600;${estadoStyle[e.estado] ?? ''}`}>
                    {e.estado}
                  </span>
                </td>
                <td style="padding:12px 16px;color:rgba(255,255,255,0.25);font-size:11px;white-space:nowrap;">
                  {new Date(e.created_at).toLocaleDateString('es-ES')}
                </td>
                <td style="padding:12px 16px;">
                  <div style="display:flex;gap:6px;flex-wrap:nowrap;">
                    {e.estado === 'pendiente' && (
                      <button onclick={`confirmarPago('${e.id}', this)`}
                        style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);color:#4ade80;font-size:11px;font-weight:600;padding:5px 10px;border-radius:6px;cursor:pointer;font-family:inherit;white-space:nowrap;transition:all 0.2s;"
                        onmouseover="this.style.background='rgba(34,197,94,0.2)'" onmouseout="this.style.background='rgba(34,197,94,0.1)'">
                        ✓ Confirmar
                      </button>
                    )}
                    <button onclick={`abrirEditar('${e.id}','${e.nombre}','${e.email}',${e.cantidad},'${e.estado}')`}
                      style="background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.25);color:#a78bfa;font-size:11px;font-weight:600;padding:5px 10px;border-radius:6px;cursor:pointer;font-family:inherit;transition:all 0.2s;"
                      onmouseover="this.style.background='rgba(124,58,237,0.2)'" onmouseout="this.style.background='rgba(124,58,237,0.1)'">
                      Editar
                    </button>
                    <button onclick={`eliminar('${e.id}', this)`}
                      style="background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);color:#f87171;font-size:11px;font-weight:600;padding:5px 10px;border-radius:6px;cursor:pointer;font-family:inherit;transition:all 0.2s;"
                      onmouseover="this.style.background='rgba(239,68,68,0.18)'" onmouseout="this.style.background='rgba(239,68,68,0.08)'">
                      Eliminar
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        {entradas.length === 0 && (
          <p style="text-align:center;color:rgba(255,255,255,0.2);padding:48px;font-size:13px;">No hay participantes registrados</p>
        )}
      </div>
    </div>
  )}

  <!-- Modal de edición -->
  <div id="modal-editar" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(8px);z-index:100;align-items:center;justify-content:center;padding:24px;">
    <div style="background:#0f0f1a;border:1px solid rgba(124,58,237,0.3);border-radius:20px;padding:28px;width:100%;max-width:440px;box-shadow:0 32px 64px rgba(0,0,0,0.6);">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
        <h3 style="color:white;font-weight:700;font-size:16px;">Editar participante</h3>
        <button onclick="cerrarModal()" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;">✕</button>
      </div>

      <input type="hidden" id="edit-id" />
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Nombre</label>
          <input id="edit-nombre" type="text"
            style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:10px 14px;font-size:13px;outline:none;font-family:inherit;box-sizing:border-box;"
            onfocus="this.style.borderColor='rgba(124,58,237,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Email</label>
          <input id="edit-email" type="email"
            style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:10px 14px;font-size:13px;outline:none;font-family:inherit;box-sizing:border-box;"
            onfocus="this.style.borderColor='rgba(124,58,237,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Cantidad</label>
          <input id="edit-cantidad" type="number" min="1"
            style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:10px 14px;font-size:13px;outline:none;font-family:inherit;box-sizing:border-box;"
            onfocus="this.style.borderColor='rgba(124,58,237,0.6)'" onblur="this.style.borderColor='rgba(255,255,255,0.1)'" />
        </div>
        <div>
          <label style="display:block;color:rgba(255,255,255,0.35);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">Estado</label>
          <select id="edit-estado"
            style="width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:white;border-radius:10px;padding:10px 14px;font-size:13px;outline:none;font-family:inherit;color-scheme:dark;box-sizing:border-box;">
            <option value="pendiente">Pendiente</option>
            <option value="pagado">Pagado</option>
            <option value="asistio">Asistió</option>
            <option value="cancelado">Cancelado</option>
          </select>
        </div>
      </div>

      <div id="modal-error" style="display:none;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);color:#f87171;font-size:12px;padding:10px 14px;border-radius:8px;margin-top:14px;"></div>

      <div style="display:flex;gap:10px;margin-top:20px;">
        <button onclick="guardarEdicion()"
          style="flex:1;background:linear-gradient(135deg,#7c3aed,#ec4899);color:white;font-weight:700;font-size:13px;padding:11px;border-radius:10px;border:none;cursor:pointer;font-family:inherit;">
          Guardar cambios
        </button>
        <button onclick="cerrarModal()"
          style="padding:11px 20px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);font-size:13px;border-radius:10px;cursor:pointer;font-family:inherit;">
          Cancelar
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  const estadoStyles: Record<string, string> = {
    pagado:    'background:rgba(124,58,237,0.12);color:#c4b5fd;border:1px solid rgba(124,58,237,0.25);',
    asistio:   'background:rgba(34,197,94,0.12);color:#4ade80;border:1px solid rgba(34,197,94,0.25);',
    pendiente: 'background:rgba(245,158,11,0.12);color:#fbbf24;border:1px solid rgba(245,158,11,0.25);',
    cancelado: 'background:rgba(239,68,68,0.12);color:#f87171;border:1px solid rgba(239,68,68,0.25);',
  };

  async function confirmarPago(id: string, btn: HTMLButtonElement) {
    btn.textContent = '...';
    const res = await fetch('/api/participante', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'confirmar', id }),
    });
    if (res.ok) {
      const row = btn.closest('tr') as HTMLElement;
      const badge = row.querySelector('.campo-estado') as HTMLElement;
      if (badge) { badge.textContent = 'pagado'; badge.style.cssText = `display:inline-block;padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600;${estadoStyles.pagado}`; }
      btn.remove();
    } else {
      btn.textContent = '✗ Error';
    }
  }

  function abrirEditar(id: string, nombre: string, email: string, cantidad: number, estado: string) {
    (document.getElementById('edit-id') as HTMLInputElement).value = id;
    (document.getElementById('edit-nombre') as HTMLInputElement).value = nombre;
    (document.getElementById('edit-email') as HTMLInputElement).value = email;
    (document.getElementById('edit-cantidad') as HTMLInputElement).value = String(cantidad);
    (document.getElementById('edit-estado') as HTMLSelectElement).value = estado;
    (document.getElementById('modal-error') as HTMLElement).style.display = 'none';
    const modal = document.getElementById('modal-editar') as HTMLElement;
    modal.style.display = 'flex';
  }

  function cerrarModal() {
    (document.getElementById('modal-editar') as HTMLElement).style.display = 'none';
  }

  async function guardarEdicion() {
    const id       = (document.getElementById('edit-id')       as HTMLInputElement).value;
    const nombre   = (document.getElementById('edit-nombre')   as HTMLInputElement).value;
    const email    = (document.getElementById('edit-email')    as HTMLInputElement).value;
    const cantidad = (document.getElementById('edit-cantidad') as HTMLInputElement).value;
    const estado   = (document.getElementById('edit-estado')   as HTMLSelectElement).value;

    const res = await fetch('/api/participante', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'editar', id, nombre, email, cantidad, estado }),
    });

    if (res.ok) {
      // Actualizar fila en la tabla
      const row = document.querySelector(`tr[data-id="${id}"]`) as HTMLElement;
      if (row) {
        (row.querySelector('.campo-nombre') as HTMLElement).textContent = nombre;
        (row.querySelector('.campo-email')  as HTMLElement).textContent = email;
        (row.querySelector('.campo-cantidad') as HTMLElement).textContent = cantidad;
        const badge = row.querySelector('.campo-estado') as HTMLElement;
        badge.textContent = estado;
        badge.style.cssText = `display:inline-block;padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600;${estadoStyles[estado] ?? ''}`;
      }
      cerrarModal();
    } else {
      const data = await res.json();
      const errEl = document.getElementById('modal-error') as HTMLElement;
      errEl.textContent = data.error ?? 'Error al guardar';
      errEl.style.display = 'block';
    }
  }

  async function eliminar(id: string, btn: HTMLButtonElement) {
    if (!confirm('¿Eliminar este participante? Esta acción no se puede deshacer.')) return;
    btn.textContent = '...';
    const res = await fetch('/api/participante', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'eliminar', id }),
    });
    if (res.ok) {
      const row = btn.closest('tr') as HTMLElement;
      row.style.opacity = '0';
      row.style.transition = 'opacity 0.3s';
      setTimeout(() => row.remove(), 300);
    } else {
      btn.textContent = 'Error';
    }
  }

  // Cerrar modal al hacer click fuera
  document.getElementById('modal-editar')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) cerrarModal();
  });

  (window as any).confirmarPago = confirmarPago;
  (window as any).abrirEditar   = abrirEditar;
  (window as any).cerrarModal   = cerrarModal;
  (window as any).guardarEdicion = guardarEdicion;
  (window as any).eliminar      = eliminar;
</script>
