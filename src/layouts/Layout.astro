---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | EventosApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <slot name="head" />
    <style>
      /* ── Navbar ── */
      .nav-links { display: flex; align-items: center; gap: 8px; }
      .nav-hamburger { display: none; }
      .nav-mobile { display: none; }

      @media (max-width: 640px) {
        .nav-links { display: none; }
        .nav-hamburger { display: flex; }
        .nav-mobile.open { display: flex; }
      }

      /* ── Hero ── */
      .hero-content { padding: 0 40px; }
      .hero-stats { width: fit-content; }
      @media (max-width: 768px) {
        .hero-content { padding: 0 20px; }
        .hero-stats { width: 100%; }
      }

      /* ── Eventos grid ── */
      .eventos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 28px; }
      @media (max-width: 768px) {
        .eventos-grid { grid-template-columns: 1fr; gap: 16px; }
      }

      /* ── Pasos grid ── */
      .pasos-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; }
      @media (max-width: 900px) {
        .pasos-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 500px) {
        .pasos-grid { grid-template-columns: 1fr; }
      }

      /* ── Evento detalle ── */
      .evento-grid { display: grid; grid-template-columns: 1fr 380px; gap: 40px; align-items: start; }
      @media (max-width: 900px) {
        .evento-grid { grid-template-columns: 1fr; }
      }

      /* ── Meta info grid ── */
      .meta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      @media (max-width: 480px) {
        .meta-grid { grid-template-columns: 1fr; }
      }

      /* ── Sección padding ── */
      .section-pad { padding: 120px 0; }
      .section-inner { max-width: 1280px; margin: 0 auto; padding: 0 40px; }
      @media (max-width: 768px) {
        .section-pad { padding: 72px 0; }
        .section-inner { padding: 0 20px; }
      }

      /* ── Hero padding ── */
      .hero-pad { padding: 0 40px 48px; }
      @media (max-width: 768px) {
        .hero-pad { padding: 0 20px 36px; }
      }

      /* ── Stats row ── */
      .stats-row { display: flex; gap: 0; border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; overflow: hidden; backdrop-filter: blur(10px); background: rgba(255,255,255,0.02); }
      @media (max-width: 400px) {
        .stats-row { flex-direction: column; }
        .stats-row > div { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .stats-row > div:last-child { border-bottom: none; }
      }

      /* ── CTA buttons ── */
      .cta-btns { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 72px; }
      @media (max-width: 480px) {
        .cta-btns { flex-direction: column; }
        .cta-btns a { text-align: center; justify-content: center; }
        .cta-btns { margin-bottom: 40px; }
      }

      /* ── Entrada card ── */
      .entrada-img-row { display: flex; gap: 0; }
      @media (max-width: 480px) {
        .entrada-img-row { flex-direction: column; }
        .entrada-img-row img { width: 100% !important; height: 140px !important; }
      }

      /* ── Mis entradas form ── */
      .mis-entradas-form { display: flex; gap: 10px; }
      @media (max-width: 480px) {
        .mis-entradas-form { flex-direction: column; }
      }

      /* ── Countdown ── */
      .countdown-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
      @media (max-width: 360px) {
        .countdown-grid { grid-template-columns: repeat(2, 1fr); }
      }

      /* ── Footer ── */
      .footer-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
      @media (max-width: 480px) {
        .footer-inner { flex-direction: column; text-align: center; }
      }
    </style>
  </head>
  <body style="font-family:'Space Grotesk',sans-serif;">

    <!-- Navbar -->
    <nav id="navbar" style="position:fixed;top:0;left:0;right:0;z-index:100;transition:all 0.3s ease;">
      <div style="max-width:1280px;margin:0 auto;padding:0 20px;height:64px;display:flex;align-items:center;justify-content:space-between;">

        <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 190 44" fill="none" style="height:40px;width:auto;display:block;">
            <defs>
              <linearGradient id="nl1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#2563eb"/><stop offset="100%" stop-color="#7c3aed"/></linearGradient>
              <linearGradient id="nl2" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#60a5fa"/><stop offset="100%" stop-color="#a78bfa"/></linearGradient>
            </defs>
            <rect x="2" y="6" width="32" height="32" rx="8" fill="url(#nl1)"/>
            <path d="M10 22 Q14 15 18 22 Q22 29 26 22" stroke="white" stroke-width="2.2" stroke-linecap="round" fill="none"/>
            <circle cx="10" cy="22" r="2" fill="white" opacity="0.9"/>
            <circle cx="26" cy="22" r="2" fill="white" opacity="0.9"/>
            <text x="42" y="26" font-family="'Space Grotesk',system-ui,sans-serif" font-size="18" font-weight="800" letter-spacing="-0.5" fill="url(#nl2)">NovaTec</text>
            <text x="43" y="38" font-family="'Space Grotesk',system-ui,sans-serif" font-size="9" font-weight="600" letter-spacing="3" fill="rgba(255,255,255,0.35)">EVENTS</text>
          </svg>
        </a>

        <!-- Desktop links -->
        <div class="nav-links">
          {[
            { href: '/#eventos',     label: 'Eventos'      },
            { href: '/mis-entradas', label: 'Mis entradas' },
          ].map(l => (
            <a href={l.href}
              style="color:rgba(255,255,255,0.5);text-decoration:none;font-size:14px;font-weight:500;padding:8px 14px;border-radius:8px;transition:all 0.2s;border:1px solid transparent;"
              onmouseover="this.style.color='white';this.style.borderColor='rgba(124,58,237,0.3)';this.style.background='rgba(124,58,237,0.08)'"
              onmouseout="this.style.color='rgba(255,255,255,0.5)';this.style.borderColor='transparent';this.style.background='transparent'">
              {l.label}
            </a>
          ))}
        </div>

        <!-- Hamburger -->
        <button class="nav-hamburger" id="hamburger"
          style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:white;width:40px;height:40px;border-radius:10px;cursor:pointer;align-items:center;justify-content:center;flex-direction:column;gap:5px;padding:0;">
          <span style="display:block;width:18px;height:2px;background:white;border-radius:2px;transition:all 0.3s;" id="h1"></span>
          <span style="display:block;width:18px;height:2px;background:white;border-radius:2px;transition:all 0.3s;" id="h2"></span>
          <span style="display:block;width:18px;height:2px;background:white;border-radius:2px;transition:all 0.3s;" id="h3"></span>
        </button>
      </div>

      <!-- Mobile menu -->
      <div class="nav-mobile" id="mobileMenu"
        style="flex-direction:column;gap:4px;padding:12px 20px 16px;background:rgba(5,5,15,0.98);border-top:1px solid rgba(255,255,255,0.06);backdrop-filter:blur(20px);">
        {[
          { href: '/',             label: 'Inicio'       },
          { href: '/#eventos',     label: 'Eventos'      },
          { href: '/mis-entradas', label: 'Mis entradas' },
        ].map(l => (
          <a href={l.href}
            style="color:rgba(255,255,255,0.6);text-decoration:none;font-size:15px;font-weight:500;padding:12px 16px;border-radius:10px;border:1px solid transparent;transition:all 0.2s;"
            onmouseover="this.style.color='white';this.style.background='rgba(124,58,237,0.1)';this.style.borderColor='rgba(124,58,237,0.2)'"
            onmouseout="this.style.color='rgba(255,255,255,0.6)';this.style.background='transparent';this.style.borderColor='transparent'">
            {l.label}
          </a>
        ))}
      </div>

      <div style="height:1px;background:linear-gradient(90deg,transparent,rgba(124,58,237,0.4),rgba(236,72,153,0.4),transparent);opacity:0.5;"></div>
    </nav>

    <div style="padding-top:64px;">
      <slot />
    </div>

    <footer style="background:#02020a;border-top:1px solid rgba(124,58,237,0.12);padding:40px 20px 28px;position:relative;overflow:hidden;">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 100%,rgba(124,58,237,0.05),transparent 70%);pointer-events:none;"></div>
      <div style="max-width:1280px;margin:0 auto;position:relative;z-index:1;">
        <div class="footer-inner">
          <div style="display:flex;align-items:center;gap:10px;">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 190 44" fill="none" style="height:34px;width:auto;display:block;">
              <defs>
                <linearGradient id="fl1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#2563eb"/><stop offset="100%" stop-color="#7c3aed"/></linearGradient>
                <linearGradient id="fl2" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#60a5fa"/><stop offset="100%" stop-color="#a78bfa"/></linearGradient>
              </defs>
              <rect x="2" y="6" width="32" height="32" rx="8" fill="url(#fl1)"/>
              <path d="M10 22 Q14 15 18 22 Q22 29 26 22" stroke="white" stroke-width="2.2" stroke-linecap="round" fill="none"/>
              <circle cx="10" cy="22" r="2" fill="white" opacity="0.9"/>
              <circle cx="26" cy="22" r="2" fill="white" opacity="0.9"/>
              <text x="42" y="26" font-family="'Space Grotesk',system-ui,sans-serif" font-size="18" font-weight="800" letter-spacing="-0.5" fill="url(#fl2)">NovaTec</text>
              <text x="43" y="38" font-family="'Space Grotesk',system-ui,sans-serif" font-size="9" font-weight="600" letter-spacing="3" fill="rgba(255,255,255,0.35)">EVENTS</text>
            </svg>
          </div>
          <p style="color:rgba(255,255,255,0.2);font-size:12px;">© {new Date().getFullYear()} EventosApp — Todos los derechos reservados</p>
        </div>
      </div>
    </footer>

    <script>
      const navbar   = document.getElementById('navbar');
      const hamburger = document.getElementById('hamburger');
      const menu     = document.getElementById('mobileMenu');
      let open = false;

      hamburger?.addEventListener('click', () => {
        open = !open;
        menu?.classList.toggle('open', open);
        const h1 = document.getElementById('h1');
        const h2 = document.getElementById('h2');
        const h3 = document.getElementById('h3');
        if (open) {
          h1!.style.transform = 'translateY(7px) rotate(45deg)';
          h2!.style.opacity   = '0';
          h3!.style.transform = 'translateY(-7px) rotate(-45deg)';
        } else {
          h1!.style.transform = '';
          h2!.style.opacity   = '1';
          h3!.style.transform = '';
        }
      });

      // Cerrar menu al hacer click en link
      menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        open = false;
        menu.classList.remove('open');
        document.getElementById('h1')!.style.transform = '';
        document.getElementById('h2')!.style.opacity   = '1';
        document.getElementById('h3')!.style.transform = '';
      }));

      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          navbar!.style.background    = 'rgba(2,2,10,0.95)';
          navbar!.style.backdropFilter = 'blur(20px)';
        } else {
          navbar!.style.background    = 'transparent';
          navbar!.style.backdropFilter = 'none';
        }
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(el => {
          if (el.isIntersecting) {
            (el.target as HTMLElement).style.opacity   = '1';
            (el.target as HTMLElement).style.transform = 'translateY(0)';
          }
        });
      }, { threshold: 0.08 });

      document.querySelectorAll('.reveal').forEach(el => {
        (el as HTMLElement).style.opacity   = '0';
        (el as HTMLElement).style.transform = 'translateY(40px)';
        (el as HTMLElement).style.transition = 'opacity 0.7s ease, transform 0.7s ease';
        observer.observe(el);
      });
    </script>
  </body>
</html>
