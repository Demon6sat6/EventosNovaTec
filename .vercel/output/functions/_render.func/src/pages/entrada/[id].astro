---
import Layout from '../../layouts/Layout.astro';
import { createServerClient } from '../../lib/supabase';
import QRDisplay from '../../components/QRDisplay';

const { id } = Astro.params;
const db = createServerClient();
const { data: entrada } = await db
  .from('entradas')
  .select('*, evento:eventos(*)')
  .eq('id', id)
  .single();

if (!entrada) return Astro.redirect('/');

const pagado   = entrada.estado === 'pagado' || entrada.estado === 'asistio';
const pendiente = entrada.estado === 'pendiente';
---
<Layout title={pagado ? 'Tu Entrada' : 'Reserva Pendiente'}>
<section style="background:#02020a;min-height:100vh;padding:60px 24px;display:flex;align-items:center;justify-content:center;">
  <div style="width:100%;max-width:460px;">

    {pendiente ? (
      <!-- ── ESTADO PENDIENTE ── -->
      <div style="background:linear-gradient(145deg,#0a0a18,#080812);border:1px solid rgba(245,158,11,0.2);border-radius:24px;overflow:hidden;box-shadow:0 0 40px rgba(245,158,11,0.06);">

        <!-- Header -->
        <div style="background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(245,158,11,0.05));padding:28px 24px;text-align:center;border-bottom:1px solid rgba(245,158,11,0.15);position:relative;overflow:hidden;">
          <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(245,158,11,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(245,158,11,0.04) 1px,transparent 1px);background-size:30px 30px;"></div>
          <div style="position:relative;z-index:1;">
            <!-- Icono de reloj animado -->
            <div style="width:64px;height:64px;background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <p style="color:#fbbf24;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;">Reserva pendiente</p>
            <h1 style="color:white;font-size:22px;font-weight:900;letter-spacing:-0.5px;">{entrada.evento?.titulo}</h1>
          </div>
        </div>

        <!-- Separador dentado -->
        <div style="position:relative;height:20px;overflow:hidden;">
          <div style="position:absolute;top:0;left:0;right:0;height:20px;background:#02020a;"
            style="mask-image:radial-gradient(circle at 50% 0%, transparent 10px, black 10px);"></div>
          <div style="display:flex;justify-content:space-between;padding:0 16px;">
            {Array.from({length:18}).map(() => (
              <div style="width:12px;height:12px;background:#02020a;border-radius:50%;margin-top:-6px;flex-shrink:0;"></div>
            ))}
          </div>
        </div>

        <!-- Info -->
        <div style="padding:20px 24px;border-bottom:1px solid rgba(255,255,255,0.05);">
          {[
            { label:'Evento',    value: entrada.evento?.titulo },
            { label:'Fecha',     value: new Date(entrada.evento?.fecha).toLocaleString('es-ES',{dateStyle:'medium',timeStyle:'short'}) },
            { label:'Lugar',     value: entrada.evento?.lugar },
            { label:'Asistente', value: entrada.nombre },
            { label:'Email',     value: entrada.email },
            { label:'Cantidad',  value: `${entrada.cantidad} entrada${entrada.cantidad > 1 ? 's' : ''}` },
            { label:'Total',     value: entrada.total === 0 ? 'Gratis' : `S/ ${entrada.total?.toFixed(2)}` },
          ].map(item => (
            <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
              <span style="color:rgba(255,255,255,0.3);font-size:12px;">{item.label}</span>
              <span style="color:white;font-size:13px;font-weight:600;text-align:right;max-width:60%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{item.value}</span>
            </div>
          ))}
        </div>

        <!-- Mensaje de espera -->
        <div style="padding:24px;text-align:center;">
          <div style="background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.2);border-radius:14px;padding:20px;margin-bottom:20px;">
            <p style="color:#fbbf24;font-weight:700;font-size:14px;margin-bottom:8px;">Esperando confirmación de pago</p>
            <p style="color:rgba(255,255,255,0.4);font-size:13px;line-height:1.6;">
              Tu reserva fue registrada. Una vez que el administrador confirme tu pago, recibirás acceso a tu código QR de entrada.
            </p>
          </div>

          <p style="color:rgba(255,255,255,0.25);font-size:12px;margin-bottom:16px;">¿Ya realizaste el pago? Envía un mensaje para confirmarlo:</p>

          <a href={`https://wa.me/51993034435?text=${encodeURIComponent(`Hola, ya realicé el pago para mi reserva.\n\nID: ${entrada.id}\nEvento: ${entrada.evento?.titulo}\nNombre: ${entrada.nombre}`)}`}
            target="_blank"
            style="display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,#25d366,#128c7e);color:white;font-weight:700;font-size:14px;padding:13px 28px;border-radius:100px;text-decoration:none;box-shadow:0 8px 24px rgba(37,211,102,0.3);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Confirmar pago por WhatsApp
          </a>

          <p style="color:rgba(255,255,255,0.15);font-size:11px;margin-top:16px;">ID de reserva: <span style="font-family:monospace;color:rgba(255,255,255,0.25);">{entrada.id.slice(0,8)}...</span></p>
        </div>
      </div>

    ) : (
      <!-- ── ENTRADA CONFIRMADA CON QR ── -->
      <div style="background:linear-gradient(145deg,#0a0a18,#080812);border:1px solid rgba(124,58,237,0.2);border-radius:24px;overflow:hidden;box-shadow:0 0 40px rgba(124,58,237,0.08);">

        <!-- Header -->
        <div style="background:linear-gradient(135deg,#7c3aed,#ec4899);padding:28px 24px;text-align:center;position:relative;overflow:hidden;">
          <div style="position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,0.08) 1px,transparent 1px);background-size:20px 20px;"></div>
          <div style="position:relative;z-index:1;">
            <p style="color:rgba(255,255,255,0.7);font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;">Entrada confirmada</p>
            <h1 style="color:white;font-size:22px;font-weight:900;letter-spacing:-0.5px;">{entrada.evento?.titulo}</h1>
          </div>
        </div>

        <!-- Separador -->
        <div style="display:flex;align-items:center;padding:0 8px;">
          <div style="width:20px;height:20px;background:#02020a;border-radius:50%;flex-shrink:0;margin-left:-10px;"></div>
          <div style="flex:1;border-top:2px dashed rgba(255,255,255,0.08);"></div>
          <div style="width:20px;height:20px;background:#02020a;border-radius:50%;flex-shrink:0;margin-right:-10px;"></div>
        </div>

        <!-- Info -->
        <div style="padding:16px 24px;border-bottom:1px solid rgba(255,255,255,0.05);">
          {[
            { label:'Fecha',     value: new Date(entrada.evento?.fecha).toLocaleString('es-ES',{dateStyle:'medium',timeStyle:'short'}) },
            { label:'Lugar',     value: entrada.evento?.lugar },
            { label:'Asistente', value: entrada.nombre },
            { label:'Cantidad',  value: `${entrada.cantidad} entrada${entrada.cantidad > 1 ? 's' : ''}` },
            { label:'Estado',    value: entrada.estado === 'asistio' ? 'Asistió' : 'Confirmado', color: entrada.estado === 'asistio' ? '#4ade80' : '#a78bfa' },
          ].map(item => (
            <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
              <span style="color:rgba(255,255,255,0.3);font-size:12px;">{item.label}</span>
              <span style={`font-size:13px;font-weight:600;color:${(item as any).color ?? 'white'};`}>{item.value}</span>
            </div>
          ))}
        </div>

        <!-- Separador -->
        <div style="display:flex;align-items:center;padding:0 8px;">
          <div style="width:20px;height:20px;background:#02020a;border-radius:50%;flex-shrink:0;margin-left:-10px;"></div>
          <div style="flex:1;border-top:2px dashed rgba(255,255,255,0.08);"></div>
          <div style="width:20px;height:20px;background:#02020a;border-radius:50%;flex-shrink:0;margin-right:-10px;"></div>
        </div>

        <!-- QR -->
        <div style="padding:28px 24px;display:flex;flex-direction:column;align-items:center;gap:12px;">
          <p style="color:rgba(255,255,255,0.35);font-size:12px;text-transform:uppercase;letter-spacing:1px;">Presenta este código en la entrada</p>
          <div style="background:white;padding:14px;border-radius:16px;box-shadow:0 0 40px rgba(124,58,237,0.2);">
            <QRDisplay client:load codigo={entrada.codigo_qr} />
          </div>
          <p style="color:rgba(255,255,255,0.15);font-size:11px;font-family:monospace;">{entrada.codigo_qr}</p>
        </div>

      </div>
    )}

    <p style="text-align:center;color:rgba(255,255,255,0.15);font-size:11px;margin-top:20px;">
      Guarda esta página o toma una captura de pantalla
    </p>
  </div>
</section>
</Layout>
