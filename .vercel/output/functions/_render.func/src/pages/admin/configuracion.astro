---
import AdminLayout from '../../layouts/AdminLayout.astro';

const env = import.meta.env.MODE;
const services = [
  { label: 'Supabase URL',      ok: !!import.meta.env.PUBLIC_SUPABASE_URL,      icon: '🗄️', desc: 'Base de datos PostgreSQL' },
  { label: 'Supabase Anon Key', ok: !!import.meta.env.PUBLIC_SUPABASE_ANON_KEY, icon: '🔑', desc: 'Clave pública de acceso' },
  { label: 'Stripe Secret Key', ok: !!import.meta.env.STRIPE_SECRET_KEY,        icon: '💳', desc: 'Procesamiento de pagos' },
  { label: 'Site URL',          ok: !!import.meta.env.PUBLIC_SITE_URL,           icon: '🌐', desc: 'URL del sitio público' },
];
const allOk = services.every(s => s.ok);
---
<AdminLayout title="Configuración">
  <div class="config-grid">

    <!-- Banner de estado general -->
    <div class={`status-banner ${allOk ? 'ok' : 'warn'}`}>
      <div class="status-icon">{allOk ? '✅' : '⚠️'}</div>
      <div>
        <p class="status-title">{allOk ? 'Todo configurado correctamente' : 'Faltan variables de entorno'}</p>
        <p class="status-sub">{allOk ? 'Todos los servicios están activos y listos.' : 'Revisá las variables marcadas abajo.'}</p>
      </div>
      <span class={`status-badge ${allOk ? 'badge-green' : 'badge-yellow'}`}>{env}</span>
    </div>

    <div class="two-col">

      <!-- Info del sistema -->
      <div class="card">
        <div class="card-header">
          <div class="card-icon" style="background:linear-gradient(135deg,#7c3aed22,#7c3aed11);border-color:#7c3aed33;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            </svg>
          </div>
          <div>
            <h3 class="card-title">Sistema</h3>
            <p class="card-sub">Información del stack</p>
          </div>
        </div>
        <div class="info-list">
          {[
            { label: 'Versión',        value: '1.0.0',              color: '#a78bfa' },
            { label: 'Framework',      value: 'Astro + React',      color: '#60a5fa' },
            { label: 'Base de datos',  value: 'Supabase (PostgreSQL)', color: '#34d399' },
            { label: 'Pagos',          value: 'Stripe',             color: '#f472b6' },
            { label: 'Entorno',        value: env,                  color: env === 'production' ? '#4ade80' : '#fbbf24' },
          ].map(item => (
            <div class="info-row">
              <span class="info-label">{item.label}</span>
              <span class="info-value" style={`color:${item.color};background:${item.color}15;border-color:${item.color}25`}>{item.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Estado de servicios -->
      <div class="card">
        <div class="card-header">
          <div class="card-icon" style="background:linear-gradient(135deg,#10b98122,#10b98111);border-color:#10b98133;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </div>
          <div>
            <h3 class="card-title">Servicios</h3>
            <p class="card-sub">Variables de entorno</p>
          </div>
        </div>
        <div class="info-list">
          {services.map(s => (
            <div class="info-row">
              <div style="display:flex;align-items:center;gap:8px;">
                <span style="font-size:14px;">{s.icon}</span>
                <div>
                  <p class="info-label" style="color:rgba(255,255,255,0.7);font-size:13px;">{s.label}</p>
                  <p style="color:rgba(255,255,255,0.25);font-size:11px;">{s.desc}</p>
                </div>
              </div>
              <span class={`service-badge ${s.ok ? 'badge-ok' : 'badge-fail'}`}>
                {s.ok ? '✓ OK' : '✗ Falta'}
              </span>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Links rápidos -->
    <div class="card">
      <div class="card-header">
        <div class="card-icon" style="background:linear-gradient(135deg,#f472b622,#f472b611);border-color:#f472b633;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f472b6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
        </div>
        <div>
          <h3 class="card-title">Links rápidos</h3>
          <p class="card-sub">Accesos directos a herramientas</p>
        </div>
      </div>
      <div class="links-grid">
        {[
          { label: 'Supabase Dashboard', url: 'https://supabase.com/dashboard',  icon: '🗄️', desc: 'Base de datos y auth',   color: '#3ecf8e' },
          { label: 'Stripe Dashboard',   url: 'https://dashboard.stripe.com',    icon: '💳', desc: 'Pagos y transacciones',  color: '#635bff' },
          { label: 'Ver sitio público',  url: '/',                               icon: '🌐', desc: 'Frontend de la app',     color: '#60a5fa' },
          { label: 'Docs Astro',         url: 'https://docs.astro.build',        icon: '📚', desc: 'Documentación oficial',  color: '#f97316' },
        ].map(item => (
          <a href={item.url} target="_blank" rel="noopener" class="link-card" style={`--accent:${item.color}`}>
            <div class="link-icon" style={`background:${item.color}15;border-color:${item.color}25`}>{item.icon}</div>
            <div class="link-info">
              <p class="link-label">{item.label}</p>
              <p class="link-desc">{item.desc}</p>
            </div>
            <svg class="link-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M7 7h10v10"/>
            </svg>
          </a>
        ))}
      </div>
    </div>

  </div>
</AdminLayout>

<style>
  .config-grid { display: flex; flex-direction: column; gap: 20px; max-width: 900px; }

  .status-banner {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 20px; border-radius: 16px; border: 1px solid;
  }
  .status-banner.ok  { background: rgba(34,197,94,0.06);  border-color: rgba(34,197,94,0.2); }
  .status-banner.warn{ background: rgba(251,191,36,0.06); border-color: rgba(251,191,36,0.2); }
  .status-icon { font-size: 22px; flex-shrink: 0; }
  .status-title { color: white; font-weight: 600; font-size: 14px; }
  .status-sub   { color: rgba(255,255,255,0.4); font-size: 12px; margin-top: 2px; }
  .status-badge {
    margin-left: auto; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1px;
    padding: 4px 10px; border-radius: 100px; border: 1px solid; flex-shrink: 0;
  }
  .badge-green  { color: #4ade80; background: rgba(74,222,128,0.1);  border-color: rgba(74,222,128,0.25); }
  .badge-yellow { color: #fbbf24; background: rgba(251,191,36,0.1);  border-color: rgba(251,191,36,0.25); }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

  .card {
    background: #0d0d1c; border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px; padding: 22px; transition: border-color 0.2s;
  }
  .card:hover { border-color: rgba(255,255,255,0.1); }

  .card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .card-icon {
    width: 40px; height: 40px; border-radius: 12px; border: 1px solid;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .card-title { color: white; font-weight: 700; font-size: 15px; }
  .card-sub   { color: rgba(255,255,255,0.3); font-size: 12px; margin-top: 2px; }

  .info-list { display: flex; flex-direction: column; gap: 2px; }
  .info-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .info-row:last-child { border-bottom: none; }
  .info-label { color: rgba(255,255,255,0.4); font-size: 13px; }
  .info-value {
    font-size: 12px; font-weight: 600; padding: 3px 10px;
    border-radius: 100px; border: 1px solid;
  }

  .service-badge {
    font-size: 11px; font-weight: 700; padding: 4px 10px;
    border-radius: 100px; border: 1px solid; flex-shrink: 0;
  }
  .badge-ok   { color: #4ade80; background: rgba(74,222,128,0.08);  border-color: rgba(74,222,128,0.2); }
  .badge-fail { color: #f87171; background: rgba(248,113,113,0.08); border-color: rgba(248,113,113,0.2); }

  .links-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .link-card {
    display: flex; align-items: center; gap: 12px;
    padding: 14px; border-radius: 14px;
    background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06);
    text-decoration: none; transition: all 0.2s; color: inherit;
  }
  .link-card:hover {
    background: rgba(255,255,255,0.05);
    border-color: var(--accent, rgba(255,255,255,0.15));
    transform: translateY(-1px);
  }
  .link-icon {
    width: 36px; height: 36px; border-radius: 10px; border: 1px solid;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; flex-shrink: 0;
  }
  .link-info { flex: 1; min-width: 0; }
  .link-label { color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600; }
  .link-desc  { color: rgba(255,255,255,0.3); font-size: 11px; margin-top: 2px; }
  .link-arrow { color: rgba(255,255,255,0.2); flex-shrink: 0; transition: color 0.2s; }
  .link-card:hover .link-arrow { color: var(--accent, rgba(255,255,255,0.6)); }

  @media (max-width: 700px) {
    .two-col, .links-grid { grid-template-columns: 1fr; }
  }
</style>
