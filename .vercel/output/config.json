{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/checkin/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/configuracion/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/eventos/nuevo/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/eventos/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/eventos/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/participantes/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/perfil/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/reportes/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/usuarios/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/perfil/actualizar/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/usuarios/crear/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/usuarios/editar/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/usuarios/toggle/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/checkin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/comprar/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/confirmar-pago/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/exportar-participantes/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/participante/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/stripe-webhook/?$",
			"dest": "_render"
		},
		{
			"src": "^/entrada/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/eventos/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/mis-entradas/?$",
			"dest": "_render"
		},
		{
			"src": "^/robots\\.txt$",
			"dest": "_render"
		},
		{
			"src": "^/sitemap\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}